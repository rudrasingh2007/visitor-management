@model IEnumerable<VisitorManagementSystem.Models.VisitEntryMaster>
@{
    ViewData["Title"] = "Visit Entry List";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-list-check me-2 text-primary"></i>Visit Entry List</h3>
            <p class="text-muted mb-0">Monitor visitor check-ins, check-outs, and track visitor logs within the premises.</p>
        </div>

    </div>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="visitsTable" style="width: 100%;">
                <thead class="table-light text-muted fs-8 fw-semibold uppercase border-bottom-0">
                    <tr>
                        <th>Visitor Name</th>
                        <th>Employee Host</th>
                        <th>Check-In Time</th>
                        <th>Check-Out Time</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var durationText = "-";
                        if (item.CheckOutTime.HasValue && item.CheckInTime.HasValue)
                        {
                            var diff = item.CheckOutTime.Value - item.CheckInTime.Value;
                            durationText = $"{(int)diff.TotalHours}h {diff.Minutes}m";
                        }
                        <tr>
                            <td class="fw-semibold text-dark">@(item.Visitor != null ? $"{item.Visitor.FirstName} {item.Visitor.LastName}" : "-")</td>
                            <td class="small">@(item.Employee != null ? $"{item.Employee.FirstName} {item.Employee.LastName}" : "-")</td>
                            <td class="small text-dark" data-order="@(item.CheckInTime.HasValue ? item.CheckInTime.Value.ToString("yyyyMMddHHmmss") : "00000000000000")">
                                @(item.CheckInTime.HasValue ? item.CheckInTime.Value.ToAppLocalTime().ToString("dd MMM yyyy") : "-")
                                <span class="text-muted d-block fs-8">@(item.CheckInTime.HasValue ? item.CheckInTime.Value.ToAppLocalTime().ToString("hh:mm tt") : "")</span>
                            </td>
                            <td class="small text-dark">
                                @(item.CheckOutTime.HasValue ? item.CheckOutTime.Value.ToAppLocalTime().ToString("dd MMM yyyy") : "-")
                                <span class="text-muted d-block fs-8">@(item.CheckOutTime.HasValue ? item.CheckOutTime.Value.ToAppLocalTime().ToString("hh:mm tt") : "")</span>
                            </td>
                            <td class="fw-bold text-secondary fs-8">@durationText</td>
                            @{
                                var statusOrder = item.VisitStatus switch {
                                    "Checked In" => "1",
                                    "Approved" => "2",
                                    "Pending" => "3",
                                    "Checked Out" => "4",
                                    "Rejected" => "5",
                                    _ => "9"
                                };
                            }
                            <td data-order="@statusOrder">
                                @switch (item.VisitStatus)
                                {
                                    case "Pending":
                                        <span class="badge bg-warning-subtle text-warning px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-hourglass-half me-1"></i>Pending</span>
                                        break;
                                    case "Approved":
                                        <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-circle-check me-1"></i>Approved</span>
                                        break;
                                    case "Rejected":
                                        <span class="badge bg-danger-subtle text-danger px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-circle-xmark me-1"></i>Rejected</span>
                                        break;
                                    case "Checked In":
                                        <span class="badge bg-info-subtle text-info px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-right-to-bracket me-1"></i>Checked In</span>
                                        break;
                                    case "Checked Out":
                                        <span class="badge bg-secondary-subtle text-secondary px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-right-from-bracket me-1"></i>Checked Out</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary px-2.5 py-1.5 rounded-pill fs-9">@item.VisitStatus</span>
                                        break;
                                }
                            </td>
                            <td class="text-end text-nowrap">
                                <a asp-action="Details" asp-route-id="@item.VisitEntryId" class="btn btn-sm btn-outline-info rounded-pill px-3 me-1" title="View Details">
                                    <i class="fa-solid fa-eye me-1"></i>View
                                </a>

                                @if (item.VisitStatus == "Approved" || item.VisitStatus == "Checked In")
                                {
                                    <a asp-action="PrintPass" asp-route-id="@item.VisitEntryId" class="btn btn-sm btn-primary rounded-pill px-3 me-1" title="Print Pass"><i class="fa-solid fa-print"></i></a>
                                }
                                else if (item.VisitStatus == "Checked Out")
                                {
                                    <a asp-action="PrintPass" asp-route-id="@item.VisitEntryId" class="btn btn-sm btn-outline-secondary rounded-pill px-3 me-1" title="View Pass"><i class="fa-solid fa-id-card-clip"></i></a>
                                }


                                @if (item.VisitStatus == "Checked In")
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 btn-trigger-checkout" 
                                            data-id="@item.VisitEntryId" 
                                            data-visitor="@(item.Visitor != null ? $"{item.Visitor.FirstName} {item.Visitor.LastName}" : "")"
                                            data-employee="@(item.Employee != null ? $"{item.Employee.FirstName} {item.Employee.LastName}" : "")"
                                            title="Check-Out Visitor">
                                        <i class="fa-solid fa-right-from-bracket"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal: Confirm Check-Out -->
<div class="modal fade" id="checkOutModal" tabindex="-1" aria-labelledby="checkOutModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="checkOutModalLabel">Visitor Check-Out</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="checkOutForm" method="post" asp-action="CheckOut">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="checkOutVisitId" />
                <div class="modal-body py-3">
                    <h5 class="fw-bold text-danger mb-2">Are you sure?</h5>
                    <p class="mb-3 text-muted small">Please record visitor check-out logs and remarks before finishing the visit record.</p>
                    <div class="p-3 bg-light rounded-3 mb-3 small">
                        <strong class="text-dark">Visitor Name: </strong><span id="checkOutVisitorName" class="fw-semibold text-primary"></span><br/>
                        <strong class="text-dark">Host Employee: </strong><span id="checkOutEmployeeName" class="fw-semibold text-primary"></span>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-semibold text-secondary small">Check-Out Remarks</label>
                        <textarea class="form-control rounded-3" name="checkoutRemarks" rows="2" placeholder="e.g. Card returned, visit concluded successfully..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4">Confirm Check-Out</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#visitsTable').DataTable({
                "order": [[5, "asc"], [2, "desc"]], // Sort by Status (Checked In first), then Check-In Time desc
                "pageLength": 10,
                "columnDefs": [
                    { "orderable": false, "targets": -1 }
                ],
                "language": {
                    "search": "",
                    "searchPlaceholder": "Search visits...",
                    "lengthMenu": "Show _MENU_ entries"
                },
                "buttons": [
                    {
                        extend: 'excel',
                        className: 'btn btn-sm btn-success text-white me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-excel me-1"></i> Excel',
                        exportOptions: { columns: ':not(:last-child)' }
                    },
                    {
                        extend: 'pdf',
                        className: 'btn btn-sm btn-danger text-white me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-pdf me-1"></i> PDF',
                        exportOptions: { columns: ':not(:last-child)' }
                    },
                    {
                        extend: 'print',
                        className: 'btn btn-sm btn-secondary text-white rounded-2',
                        text: '<i class="fa-solid fa-print me-1"></i> Print',
                        exportOptions: { columns: ':not(:last-child)' }
                    }
                ],
                "dom": "<'row mb-3'<'col-sm-12 col-md-6'lB><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            // Trigger Check-Out confirmation Modal
            $(document).on('click', '.btn-trigger-checkout', function() {
                var visitId = $(this).data('id');
                var visitorName = $(this).data('visitor');
                var employeeName = $(this).data('employee');
                
                $('#checkOutVisitId').val(visitId);
                $('#checkOutVisitorName').text(visitorName);
                $('#checkOutEmployeeName').text(employeeName);
                
                var myModal = new bootstrap.Modal(document.getElementById('checkOutModal'));
                myModal.show();
            });
        });
    </script>
}


