@model VisitorManagementSystem.Models.DepartmentMaster
@{
    ViewData["Title"] = "Edit Department";
}

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Department List</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit Department</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-pen-to-square me-2 text-primary"></i>Edit Department</h3>
        <p class="text-muted mb-0">Modify details of an existing department.</p>
    </div>

    <div class="row">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" autocomplete="off">
                        @Html.AntiForgeryToken()
                        
                        <input type="hidden" asp-for="DepartmentId" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <!-- Department Name -->
                        <div class="mb-3">
                            <label asp-for="DepartmentName" class="form-label fw-semibold text-dark">Department Name <span class="text-danger">*</span></label>
                            <input asp-for="DepartmentName" class="form-control rounded-2 p-2" required />
                            <span asp-validation-for="DepartmentName" class="text-danger small"></span>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold text-dark">Description</label>
                            <textarea asp-for="Description" class="form-control rounded-2 p-2" rows="3" placeholder="Enter department description..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <!-- Status dropdown -->
                        <div class="mb-4">
                            <label asp-for="Status" class="form-label fw-semibold text-dark">Status <span class="text-danger">*</span></label>
                            <select asp-for="Status" class="form-select rounded-2 p-2" required>
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4 py-2 fw-semibold rounded-2 shadow-sm">
                                <i class="fa-solid fa-save me-2"></i>Update Department
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-2">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
