@model VisitorManagementSystem.Models.GatePassMaster
@{
    Layout = null;
    var checkInDate = Model.VisitEntry != null ? Model.VisitEntry.CheckInTime.ToLocalTime().ToString("dd-MM-yyyy") : "Pending Check-In";
    var checkInTime = Model.VisitEntry != null ? Model.VisitEntry.CheckInTime.ToLocalTime().ToString("hh:mm tt") : "Pending Check-In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gate Pass - @Model.GatePassNumber</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            background-color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .badge-container {
            width: 380px;
            margin: 20px auto;
            border: 2px dashed #94a3b8;
            border-radius: 16px;
            padding: 24px;
            background: #ffffff;
            position: relative;
        }

        .badge-header {
            text-align: center;
            border-bottom: 2px solid #0f172a;
            padding-bottom: 12px;
            margin-bottom: 16px;
        }

        .org-logo {
            font-size: 1.35rem;
            font-weight: 800;
            color: #0f172a;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .pass-number {
            font-size: 0.85rem;
            color: #475569;
            font-weight: 700;
            font-family: monospace;
            margin-top: 4px;
        }

        .badge-photo-name-sec {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 16px;
        }

        .visitor-photo {
            width: 100px;
            height: 100px;
            border-radius: 12px;
            border: 2px solid #0f172a;
            object-fit: cover;
        }

        .photo-placeholder {
            width: 100px;
            height: 100px;
            border-radius: 12px;
            border: 2px dashed #cbd5e1;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #94a3b8;
            background-color: #f8fafc;
        }

        .visitor-meta {
            flex: 1;
        }

        .visitor-name {
            font-size: 1.25rem;
            font-weight: 800;
            color: #0f172a;
            line-height: 1.2;
            margin-bottom: 4px;
        }

        .pass-status-badge {
            font-size: 0.75rem;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 50px;
            display: inline-block;
            text-transform: uppercase;
        }

        .status-approved {
            background-color: #e0f2fe;
            color: #0369a1;
        }

        .status-checkedin {
            background-color: #dcfce7;
            color: #15803d;
        }

        .status-checkedout {
            background-color: #f1f5f9;
            color: #475569;
        }

        .qr-section {
            text-align: center;
            margin-bottom: 16px;
        }

        .qr-code {
            width: 120px;
            height: 120px;
            border: 1px solid #e2e8f0;
            padding: 4px;
            border-radius: 8px;
        }

        .details-section {
            border-top: 1px solid #e2e8f0;
            padding-top: 12px;
            margin-bottom: 20px;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            font-size: 0.8rem;
            padding: 4px 0;
        }

        .detail-label {
            color: #64748b;
            font-weight: 600;
        }

        .detail-value {
            color: #0f172a;
            font-weight: 700;
            text-align: right;
            max-width: 65%;
        }

        .badge-signatures {
            display: flex;
            justify-content: space-between;
            margin-top: 24px;
            border-top: 1px solid #cbd5e1;
            padding-top: 16px;
        }

        .sig-line {
            width: 45%;
            text-align: center;
            font-size: 0.65rem;
            color: #64748b;
            font-weight: 600;
        }

        .sig-space {
            height: 35px;
        }

        .sig-label {
            border-top: 1px solid #94a3b8;
            padding-top: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .no-print-btn {
            text-align: center;
            margin-top: 20px;
        }

        .cut-instruction {
            text-align: center;
            font-size: 0.7rem;
            color: #94a3b8;
            margin-top: 12px;
            font-style: italic;
        }

        @@media print {
            body {
                background: none;
                margin: 0;
                padding: 0;
            }
            
            .no-print {
                display: none !important;
            }

            .badge-container {
                margin: 0 auto;
                box-shadow: none;
                page-break-inside: avoid;
            }

            .cut-instruction {
                display: none;
            }
        }
    </style>
</head>
<body>

    <div class="no-print no-print-btn">
        <button onclick="window.print();" class="btn btn-dark px-4 py-2 fw-bold rounded-pill shadow-sm">
            <i class="fa-solid fa-print me-2"></i>Print Pass Now
        </button>
        <button onclick="window.close();" class="btn btn-outline-secondary px-3 py-2 rounded-pill ms-2">
            Close Window
        </button>
    </div>

    <div class="badge-container">
        <!-- Header -->
        <div class="badge-header">
            <div class="org-logo">VMS Corporate</div>
            <div class="pass-number">PASS NO: @Model.GatePassNumber</div>
        </div>

        <!-- Photo and Visitor Name -->
        <div class="badge-photo-name-sec">
            @if (Model.Visitor != null && !string.IsNullOrEmpty(Model.Visitor.PhotoPath))
            {
                <img src="@Model.Visitor.PhotoPath" class="visitor-photo" alt="Visitor Photo" />
            }
            else
            {
                <div class="photo-placeholder">
                    <i class="fa-solid fa-user fa-3x"></i>
                </div>
            }
            <div class="visitor-meta">
                <div class="visitor-name">@(Model.Visitor?.FirstName + " " + Model.Visitor?.LastName)</div>
                <div>
                    @if (Model.Status == "Approved")
                    {
                        <span class="pass-status-badge status-approved">Approved</span>
                    }
                    else if (Model.Status == "Checked In")
                    {
                        <span class="pass-status-badge status-checkedin">Checked In</span>
                    }
                    else
                    {
                        <span class="pass-status-badge status-checkedout">Checked Out</span>
                    }
                </div>
            </div>
        </div>

        <!-- QR Code -->
        <div class="qr-section">
            <img src="@Model.QRCodePath" class="qr-code" alt="Pass QR Code" />
        </div>

        <!-- Details Section -->
        <div class="details-section">
            <div class="detail-row">
                <span class="detail-label">Mobile Number</span>
                <span class="detail-value">@(Model.Visitor?.MobileNumber ?? "N/A")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Company Name</span>
                <span class="detail-value">@(Model.Visitor?.CompanyName ?? "N/A")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Employee Host</span>
                <span class="detail-value">@(Model.Employee?.FirstName + " " + Model.Employee?.LastName)</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Department</span>
                <span class="detail-value">@(Model.Department?.DepartmentName ?? "N/A")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Purpose of Visit</span>
                <span class="detail-value">@(Model.EntryRequest?.Purpose ?? Model.VisitEntry?.Appointment?.Purpose ?? "N/A")</span>
            </div>
            
            <div class="detail-row mt-2 pt-2 border-top border-light">
                <span class="detail-label">Check-In Date</span>
                <span class="detail-value">@checkInDate</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Check-In Time</span>
                <span class="detail-value text-primary">@checkInTime</span>
            </div>
        </div>

        <!-- Signatures / Stamp Footer -->
        <div class="badge-signatures">
            <div class="sig-line">
                <div class="sig-space"></div>
                <div class="sig-label">Authorized Host</div>
            </div>
            <div class="sig-line">
                <div class="sig-space"></div>
                <div class="sig-label">Security Verify</div>
            </div>
        </div>
    </div>

    <div class="cut-instruction">
        <i class="fa-solid fa-scissors me-1"></i>Cut along the dotted line and insert into the badge holder.
    </div>

    <script>
        window.onload = function() {
            setTimeout(function() {
                window.print();
            }, 600);
        };
    </script>
</body>
</html>
