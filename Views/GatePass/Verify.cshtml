@model VisitorManagementSystem.Models.GatePassMaster
@{
    Layout = null;
    var status = ViewBag.Status as string ?? "Invalid";
    var message = ViewBag.Message as string ?? "PASS CLOSED / INVALID";
    var isPassed = status == "Valid";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gate Pass Verification</title>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            background-color: #f3f4f6;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .verify-card {
            max-width: 500px;
            width: 100%;
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            border: none;
        }

        .status-header {
            padding: 30px 20px;
            text-align: center;
            color: #ffffff;
            font-weight: 800;
            font-size: 1.5rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .status-header.valid {
            background: linear-gradient(135deg, #10b981, #059669);
        }

        .status-header.invalid {
            background: linear-gradient(135deg, #ef4444, #dc2626);
        }

        .status-icon {
            font-size: 3.5rem;
            margin-bottom: 15px;
            animation: pulse 2s infinite;
        }

        .visitor-photo-box {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 4px solid #ffffff;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            object-fit: cover;
            margin: -60px auto 15px auto;
            display: block;
            background: #f8fafc;
        }

        .info-label {
            font-size: 0.75rem;
            color: #64748b;
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .info-value {
            font-size: 0.95rem;
            color: #1e293b;
            font-weight: 700;
        }

        .badge-status {
            font-size: 0.8rem;
            padding: 6px 16px;
            border-radius: 50px;
            font-weight: 700;
            display: inline-block;
        }

        @@keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.08); }
            100% { transform: scale(1); }
        }
    </style>
</head>
<body>

    <div class="verify-card">
        <!-- Status Header -->
        <div class="status-header @(isPassed ? "valid" : "invalid")">
            <div class="status-icon">
                @if (isPassed)
                {
                    <i class="fa-solid fa-circle-check"></i>
                }
                else
                {
                    <i class="fa-solid fa-circle-xmark"></i>
                }
            </div>
            @message
        </div>

        <div class="card-body p-4 pt-5 position-relative">
            @if (Model != null)
            {
                
                var passModel = new VisitorManagementSystem.ViewModels.PassTemplateViewModel
                {
                    GatePassNumber = Model.GatePassNumber,
                    VisitorName = Model.Visitor?.FirstName + " " + Model.Visitor?.LastName,
                    MobileNumber = Model.Visitor?.MobileNumber,
                    EmployeeName = Model.Employee?.FirstName + " " + Model.Employee?.LastName,
                    Purpose = Model.EntryRequest?.Purpose ?? Model.VisitEntry?.Appointment?.Purpose ?? "N/A",
                    VisitDate = Model.VisitEntry?.CheckInTime?.ToLocalTime().ToString("dd-MM-yyyy") ?? Model.IssueDateTime.ToLocalTime().ToString("dd-MM-yyyy"),
                    CheckInTime = Model.VisitEntry?.CheckInTime?.ToLocalTime().ToString("hh:mm tt") ?? "Pending Check-In",
                    Status = Model.Status,
                    PhotoPath = Model.Visitor?.PhotoPath,
                    QRCodePath = Model.QRCodePath
                };
                
                @await Html.PartialAsync("_PassTemplate", passModel)
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="fa-solid fa-triangle-exclamation fa-2x mb-3 text-warning"></i>
                    <p class="mb-0 small">No gate pass matching this verification request could be found. Access is denied.</p>
                </div>
            }
        </div>
    </div>

</body>
</html>
