@model VisitorManagementSystem.Models.GatePassMaster
@{
    ViewData["Title"] = "Gate Pass Details";
    var isExpired = Model.Status == "Active" && DateTime.UtcNow > Model.ExpiryDateTime;
    var currentStatus = isExpired ? "Expired" : Model.Status;
}

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="GatePass" asp-action="Index" class="text-decoration-none">Gate Pass Management</a></li>
            <li class="breadcrumb-item active" aria-current="page">Gate Pass Details</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-id-card-clip me-2 text-primary"></i>Gate Pass Details</h3>
            <p class="text-muted mb-0">Review the issued visitor credentials, dynamic QR code, and validity period.</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary px-3 py-2 fw-semibold rounded-2 me-2">
                <i class="fa-solid fa-arrow-left me-1"></i>Back to List
            </a>
            <a asp-action="Print" asp-route-id="@Model.GatePassId" target="_blank" class="btn btn-success px-4 py-2 fw-semibold shadow-sm">
                <i class="fa-solid fa-print me-1"></i>Print Gate Pass
            </a>
        </div>
    </div>

    <!-- Pass Badging Layout -->
    <div class="row g-4 justify-content-center">
        <!-- Digital Gate Pass Badge Design Card -->
        <div class="col-12 col-md-5 col-lg-4">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="border-top: 5px solid #1e3c72 !important;">
                <div class="card-body p-4 text-center">
                    <div class="mb-3">
                        <span class="fs-7 text-uppercase tracking-wider fw-bold text-muted d-block">Visitor Gate Pass</span>
                        <h4 class="fw-bold text-primary mb-0">@Model.GatePassNumber</h4>
                    </div>

                    <!-- Visitor Photo in Badge -->
                    <div class="mx-auto my-3 border rounded-circle shadow-sm bg-white d-flex align-items-center justify-content-center" style="width: 140px; height: 140px; overflow: hidden; border: 4px solid #fff !important;">
                        @if (!string.IsNullOrEmpty(Model.Visitor?.PhotoPath))
                        {
                            <img src="@Model.Visitor.PhotoPath" class="img-fluid" style="width: 100%; height: 100%; object-fit: cover;" alt="Visitor Picture" />
                        }
                        else
                        {
                            <i class="fa-solid fa-user fa-5x text-muted opacity-50"></i>
                        }
                    </div>

                    <h5 class="fw-bold text-dark mb-0">@(Model.Visitor?.FirstName + " " + Model.Visitor?.LastName)</h5>
                    <span class="text-muted small">@(Model.Visitor?.CompanyName ?? "Individual Visitor")</span>

                    <!-- Status Indicator Badge -->
                    <div class="my-3">
                        @if (currentStatus == "Active")
                        {
                            <span class="badge bg-success-subtle text-success px-3 py-2 fs-7 rounded-pill">
                                <i class="fa-solid fa-circle-check me-1"></i>Active Pass
                            </span>
                        }
                        else if (currentStatus == "Expired")
                        {
                            <span class="badge bg-danger-subtle text-danger px-3 py-2 fs-7 rounded-pill">
                                <i class="fa-solid fa-circle-exclamation me-1"></i>Expired Pass
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary px-3 py-2 fs-7 rounded-pill">
                                <i class="fa-solid fa-lock me-1"></i>Closed Pass
                            </span>
                        }
                    </div>

                    <!-- QR Code Image -->
                    <div class="bg-light p-3 rounded-4 border d-inline-block mx-auto mb-2 shadow-inner">
                        <img src="@Model.QRCodePath" class="img-fluid" style="max-width: 160px;" alt="Gate Pass QR Code" />
                        <span class="d-block text-muted fs-8 mt-2"><i class="fa-solid fa-qrcode me-1"></i>Scan at gate check-out</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Meta Details and Timeline Info Card -->
        <div class="col-12 col-md-7 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-dark mb-4 border-bottom pb-2">
                        <i class="fa-solid fa-circle-info text-primary me-2"></i>Pass Information
                    </h5>
                    
                    <div class="row g-3">
                        <!-- Visitor Details -->
                        <div class="col-12 col-sm-6">
                            <span class="text-muted small d-block">Visitor Mobile Number</span>
                            <span class="fw-semibold text-dark">@(Model.Visitor?.MobileNumber ?? "N/A")</span>
                        </div>
                        <div class="col-12 col-sm-6">
                            <span class="text-muted small d-block">Visitor Email Address</span>
                            <span class="fw-semibold text-dark text-truncate d-block">@(Model.Visitor?.Email ?? "N/A")</span>
                        </div>

                        <hr class="text-muted opacity-25 my-3" />

                        <!-- Host Details -->
                        <div class="col-12 col-sm-6">
                            <span class="text-muted small d-block">Host Employee</span>
                            <span class="fw-semibold text-dark">@(Model.Employee?.FirstName + " " + Model.Employee?.LastName)</span>
                        </div>
                        <div class="col-12 col-sm-6">
                            <span class="text-muted small d-block">Department & Designation</span>
                            <span class="fw-semibold text-dark">
                                @(Model.Department?.DepartmentName ?? "N/A") - @(Model.Employee?.Designation ?? "N/A")
                            </span>
                        </div>

                        <hr class="text-muted opacity-25 my-3" />

                        <!-- Visit Details -->
                        <div class="col-12 col-sm-6">
                            <span class="text-muted small d-block">Check-In Log Reference</span>
                            <a asp-controller="Visit" asp-action="Details" asp-route-id="@Model.VisitEntryId" class="fw-semibold text-primary text-decoration-none">
                                Check-In Record <i class="fa-solid fa-arrow-up-right-from-square fs-8 ms-1"></i>
                            </a>
                        </div>
                        <div class="col-12 col-sm-6">
                            <span class="text-muted small d-block">Check-In Type</span>
                            <span class="fw-semibold text-dark">@(Model.VisitEntry != null ? "Scheduled Appointment" : "Walk-In")</span>
                        </div>

                        <hr class="text-muted opacity-25 my-3" />

                        <!-- Expiry and Issue -->
                        <div class="col-12 col-sm-6">
                            <span class="text-muted small d-block">Issued On</span>
                            <span class="fw-semibold text-success">
                                <i class="fa-regular fa-calendar-check me-1"></i>@Model.IssueDateTime.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")
                            </span>
                        </div>
                        <div class="col-12 col-sm-6">
                            <span class="text-muted small d-block">Valid Until (12-Hour Expiry)</span>
                            <span class="fw-semibold text-danger">
                                <i class="fa-regular fa-calendar-times me-1"></i>@Model.ExpiryDateTime.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")
                            </span>
                        </div>
                    </div>

                    <!-- Warnings or expiry banner -->
                    @if (isExpired)
                    {
                        <div class="alert alert-danger bg-danger-subtle border-0 rounded-3 mt-4 mb-0 fs-7" role="alert">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i><strong>This pass has expired!</strong> The 12-hour validity window has elapsed. Visitor check-out scan must be triggered.
                        </div>
                    }
                    else if (Model.Status == "Closed")
                    {
                        <div class="alert alert-secondary bg-secondary-subtle border-0 rounded-3 mt-4 mb-0 fs-7" role="alert">
                            <i class="fa-solid fa-lock me-2"></i><strong>This pass is closed.</strong> The visitor has already checked out.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-success bg-success-subtle border-0 rounded-3 mt-4 mb-0 fs-7 text-success" role="alert">
                            <i class="fa-solid fa-clock-rotate-left me-2"></i><strong>Valid credentials.</strong> This pass is currently valid and active for security access verification.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-primary { color: #1e3c72 !important; }
    .bg-light { background-color: #f8f9fa !important; }
    .shadow-inner {
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.06);
    }
    .tracking-wider {
        letter-spacing: 0.08em;
    }
    .fs-7 { font-size: 0.85rem; }
    .fs-8 { font-size: 0.75rem; }
</style>
