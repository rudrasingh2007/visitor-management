@model IEnumerable<VisitorManagementSystem.Models.GatePassMaster>
@{
    ViewData["Title"] = "Gate Pass List";
}

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item text-muted">Gate Pass Management</li>
            <li class="breadcrumb-item active" aria-current="page">Gate Pass List</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-ticket me-2 text-primary"></i>Gate Pass List</h3>
            <p class="text-muted mb-0">View, search, print, and track security gate passes issued to active visitors.</p>
        </div>
        <div>
            <a asp-action="Generate" class="btn btn-primary px-4 py-2 fw-semibold shadow-sm">
                <i class="fa-solid fa-plus me-2"></i>Generate Gate Pass
            </a>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" onclick="$(this).closest('.alert').remove()"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" onclick="$(this).closest('.alert').remove()"></button>
        </div>
    }

    <!-- Advanced Filters Card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-sliders text-primary me-2"></i>Filter Gate Passes</h6>
            <div class="row g-3">
                <!-- Status Filter -->
                <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                    <label class="form-label fw-semibold text-muted small mb-1">Status</label>
                    <select id="statusFilter" class="form-select rounded-2">
                        <option value="">All Statuses</option>
                        <option value="Active">Active</option>
                        <option value="Expired">Expired</option>
                        <option value="Closed">Closed</option>
                    </select>
                </div>
                <!-- Visitor Filter -->
                <div class="col-12 col-sm-6 col-md-3 col-lg-3">
                    <label class="form-label fw-semibold text-muted small mb-1">Visitor</label>
                    <select id="visitorFilter" class="form-select rounded-2" asp-items="ViewBag.VisitorsList">
                        <option value="">All Visitors</option>
                    </select>
                </div>
                <!-- Employee Filter -->
                <div class="col-12 col-sm-6 col-md-3 col-lg-3">
                    <label class="form-label fw-semibold text-muted small mb-1">Employee Host</label>
                    <select id="employeeFilter" class="form-select rounded-2" asp-items="ViewBag.EmployeesList">
                        <option value="">All Employees</option>
                    </select>
                </div>
                <!-- Issue Date Filter -->
                <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                    <label class="form-label fw-semibold text-muted small mb-1">Issue Date</label>
                    <input type="date" id="dateFilter" class="form-control rounded-2" />
                </div>
            </div>
            <!-- Reset Button -->
            <div class="d-flex justify-content-end mt-3">
                <button type="button" id="btnResetFilters" class="btn btn-sm btn-outline-secondary rounded-2">
                    <i class="fa-solid fa-arrow-rotate-left me-1"></i>Reset Filters
                </button>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle" id="gatePassTable" style="width: 100%;">
                    <thead class="table-light text-muted uppercase fs-7 fw-semibold">
                        <tr>
                            <th>Pass Number</th>
                            <th>Visitor Name</th>
                            <th>Department</th>
                            <th>Employee Host</th>
                            <th>Issue Time</th>
                            <th>Expiry Time</th>
                            <th>Status</th>
                            <th class="text-end" style="min-width: 120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var isExpired = item.Status == "Active" && DateTime.UtcNow > item.ExpiryDateTime;
                            var currentStatus = isExpired ? "Expired" : item.Status;
                            
                            <tr>
                                <td class="fw-bold text-dark">
                                    <i class="fa-solid fa-ticket text-primary-emphasis me-1"></i>@item.GatePassNumber
                                </td>
                                <td class="fw-semibold">
                                    @(item.Visitor != null ? $"{item.Visitor.FirstName} {item.Visitor.LastName}" : "Unknown")
                                </td>
                                <td>
                                    <span class="badge bg-secondary-subtle text-secondary px-2 py-1 fs-8">
                                        @(item.Department?.DepartmentName ?? "N/A")
                                    </span>
                                </td>
                                <td>
                                    @(item.Employee != null ? $"{item.Employee.FirstName} {item.Employee.LastName}" : "Unknown")
                                </td>
                                <td class="pass-date" data-date="@item.IssueDateTime.ToLocalTime().ToString("yyyy-MM-dd")" data-order="@item.IssueDateTime.ToString("yyyyMMddHHmmss")">
                                    @item.IssueDateTime.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")
                                </td>
                                <td>
                                    @item.ExpiryDateTime.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")
                                </td>
                                <td>
                                    @if (currentStatus == "Active")
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 fs-8 rounded-pill">
                                            <i class="fa-solid fa-circle-check me-1"></i>Active
                                        </span>
                                    }
                                    else if (currentStatus == "Expired")
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 fs-8 rounded-pill">
                                            <i class="fa-solid fa-clock-rotate-left me-1"></i>Expired
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-3 py-2 fs-8 rounded-pill">
                                            <i class="fa-solid fa-folder-closed me-1"></i>Closed
                                        </span>
                                    }
                                </td>
                                <td class="text-end">
                                    <!-- View Details -->
                                    <a asp-action="Details" asp-route-id="@item.GatePassId" class="btn btn-sm btn-outline-info me-1 rounded-2" title="View Details">
                                        <i class="fa-solid fa-circle-info"></i>
                                    </a>
                                    <!-- Print -->
                                    <a asp-action="Print" asp-route-id="@item.GatePassId" target="_blank" class="btn btn-sm btn-outline-secondary rounded-2" title="Print Gate Pass">
                                        <i class="fa-solid fa-print"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize DataTable
            var table = $('#gatePassTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search passes..."
                },
                "order": [[4, "desc"]], // Sort by Issue Time desc
                "buttons": [
                    {
                        extend: 'excel',
                        className: 'btn btn-sm btn-outline-success me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-excel me-1"></i> Excel',
                        exportOptions: { columns: [0, 1, 2, 3, 4, 5, 6] }
                    },
                    {
                        extend: 'pdf',
                        className: 'btn btn-sm btn-outline-danger me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-pdf me-1"></i> PDF',
                        exportOptions: { columns: [0, 1, 2, 3, 4, 5, 6] }
                    },
                    {
                        extend: 'print',
                        className: 'btn btn-sm btn-outline-secondary rounded-2',
                        text: '<i class="fa-solid fa-print me-1"></i> Print Table',
                        exportOptions: { columns: [0, 1, 2, 3, 4, 5, 6] }
                    }
                ],
                "dom": "<'row mb-3'<'col-sm-12 col-md-6'lB><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            // Status Filter Dropdown
            $('#statusFilter').on('change', function() {
                var val = $(this).val();
                table.column(6).search(val ? '^\\s*' + val + '\\s*$' : '', true, false).draw();
            });

            // Visitor Filter Dropdown
            $('#visitorFilter').on('change', function() {
                var val = $(this).val();
                table.column(1).search(val ? '^\\s*' + val + '\\s*$' : '', true, false).draw();
            });

            // Employee Filter Dropdown
            $('#employeeFilter').on('change', function() {
                var val = $(this).val();
                table.column(3).search(val ? '^\\s*' + val + '\\s*$' : '', true, false).draw();
            });

            // Custom search plugin to filter rows by issue date
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    var filterDate = $('#dateFilter').val(); // YYYY-MM-DD
                    if (!filterDate) {
                        return true;
                    }
                    var rowDateStr = $(table.row(dataIndex).node()).find('td.pass-date').attr('data-date');
                    return rowDateStr === filterDate;
                }
            );

            // Re-draw table when date filter changes
            $('#dateFilter').on('change', function() {
                table.draw();
            });

            // Reset Filters
            $('#btnResetFilters').click(function() {
                $('#statusFilter').val('');
                $('#visitorFilter').val('');
                $('#employeeFilter').val('');
                $('#dateFilter').val('');
                
                table.column(6).search('');
                table.column(1).search('');
                table.column(3).search('');
                table.draw();
            });
        });
    </script>
}
