@model VisitorManagementSystem.ViewModels.GatePassViewModel
@{
    ViewData["Title"] = "Generate Gate Pass";
}

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item text-muted">Gate Pass Management</li>
            <li class="breadcrumb-item active" aria-current="page">Generate Gate Pass</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-address-card me-2 text-primary"></i>Generate Gate Pass</h3>
        <p class="text-muted mb-0">Select an active Checked-In visitor log to automatically generate their secure Gate Pass and scannable QR Code.</p>
    </div>

    <!-- Form Card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4 p-md-5">
            <form asp-action="Generate" method="post" id="generateGatePassForm">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 p-3 mb-4 fs-7" role="alert">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>Please correct the errors below.
                </div>

                <div class="row g-3 align-items-end mb-4">
                    <!-- Visit Entry Selection -->
                    <div class="col-12 col-md-8">
                        <label asp-for="VisitEntryId" class="form-label fw-semibold text-secondary">Select Checked-In Visitor Record <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="fa-solid fa-door-open"></i></span>
                            <select asp-for="VisitEntryId" class="form-select border-start-0 rounded-end-3" asp-items="ViewBag.VisitsList" id="VisitEntryId">
                                <option value="">-- Choose Active Visit Entry --</option>
                            </select>
                        </div>
                        <span asp-validation-for="VisitEntryId" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="col-12 col-md-4">
                        <span class="text-muted small"><i class="fa-solid fa-info-circle me-1"></i>Only showing visitors currently checked in without an active pass.</span>
                    </div>
                </div>

                <!-- Auto-Populated Visit Details Container -->
                <div id="detailsContainer" style="display: none;">
                    <div class="row g-4">
                        <!-- Visitor Details Card -->
                        <div class="col-12 col-md-6">
                            <div class="card border-0 bg-light rounded-4 h-100 p-3 shadow-sm border-start border-primary border-4">
                                <div class="d-flex align-items-center mb-3">
                                    <h6 class="fw-bold text-primary mb-0"><i class="fa-solid fa-id-badge me-2"></i>Visitor Information</h6>
                                </div>
                                <div class="d-flex gap-3 align-items-start">
                                    <!-- Visitor Photo Dynamic -->
                                    <div id="visitorPhotoWrapper" class="flex-shrink-0 bg-white border rounded shadow-sm text-center d-flex align-items-center justify-content-center" style="width: 100px; height: 100px; overflow: hidden;">
                                        <i class="fa-solid fa-user fa-3x text-muted" id="placeholderPhoto"></i>
                                        <img src="" id="visitorImg" class="img-fluid" style="display:none; object-fit: cover; width:100%; height:100%;" alt="Visitor Picture" />
                                    </div>
                                    <div class="row g-2 small flex-grow-1">
                                        <div class="col-4 text-muted">Full Name:</div>
                                        <div class="col-8 fw-semibold text-dark" id="txtVisitorName"></div>
                                        
                                        <div class="col-4 text-muted">Mobile No:</div>
                                        <div class="col-8 fw-semibold text-dark" id="txtVisitorMobile"></div>
                                        
                                        <div class="col-4 text-muted">Company:</div>
                                        <div class="col-8 fw-semibold text-dark" id="txtVisitorCompany"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Employee Details Card -->
                        <div class="col-12 col-md-6">
                            <div class="card border-0 bg-light rounded-4 h-100 p-3 shadow-sm border-start border-success border-4">
                                <h6 class="fw-bold text-success mb-3"><i class="fa-solid fa-user-tie me-2"></i>Host Employee Information</h6>
                                <div class="row g-2 small">
                                    <div class="col-4 text-muted">Host Name:</div>
                                    <div class="col-8 fw-semibold text-dark" id="txtEmployeeName"></div>
                                    
                                    <div class="col-4 text-muted">Designation:</div>
                                    <div class="col-8 fw-semibold text-dark" id="txtEmployeeDesignation"></div>
                                    
                                    <div class="col-4 text-muted">Department:</div>
                                    <div class="col-8 fw-semibold text-dark" id="txtDepartmentName"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Visit details -->
                        <div class="col-12">
                            <div class="card border-0 bg-light rounded-4 p-3 shadow-sm border-start border-warning border-4">
                                <h6 class="fw-bold text-warning mb-2"><i class="fa-solid fa-circle-question me-2"></i>Arrival Status & Schedule</h6>
                                <div class="row g-2 small mb-2">
                                    <div class="col-12 col-sm-6">
                                        <span class="text-muted me-1">Check-In Time:</span>
                                        <strong class="text-dark" id="txtCheckInTime"></strong>
                                    </div>
                                </div>
                                <span class="text-muted d-block mb-1">Purpose of Visit:</span>
                                <div class="p-2 bg-white rounded text-dark fs-7" id="txtPurpose"></div>
                            </div>
                        </div>

                        <!-- Remarks Input -->
                        <div class="col-12">
                            <label asp-for="Remarks" class="form-label fw-semibold text-secondary">Gate Pass Remarks / Special Instructions</label>
                            <textarea asp-for="Remarks" rows="2" class="form-control rounded-3" placeholder="Enter security instructions, restricted zones, or item handovers..."></textarea>
                            <span asp-validation-for="Remarks" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-end gap-2 mt-5">
                        <a asp-action="Index" class="btn btn-secondary px-4 py-2 rounded-3 fw-semibold">
                            <i class="fa-solid fa-xmark me-2"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-primary px-4 py-2 rounded-3 fw-semibold shadow-sm">
                            <i class="fa-solid fa-ticket me-2"></i>Generate Gate Pass
                        </button>
                    </div>
                </div>
                
                <!-- Placeholder when no visit entry is selected -->
                <div id="placeholderMessage" class="text-center py-5">
                    <div class="text-muted mb-2">
                        <i class="fa-solid fa-qrcode fa-4x mb-3 text-secondary"></i>
                        <p class="fw-semibold">No Visit Log Selected</p>
                        <p class="small text-muted mx-auto" style="max-width: 400px;">Please choose an active Checked-In visitor log from the dropdown above to load visit details.</p>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Function to load visit entry details
            function loadVisitDetails(visitId) {
                if (!visitId) {
                    $('#detailsContainer').hide();
                    $('#placeholderMessage').show();
                    return;
                }

                $.getJSON('@Url.Action("GetVisitDetails", "GatePass")', { visitEntryId: visitId }, function(data) {
                    if (data) {
                        $('#txtVisitorName').text(data.visitorName);
                        $('#txtVisitorMobile').text(data.visitorMobile);
                        $('#txtVisitorCompany').text(data.visitorCompany);
                        
                        $('#txtEmployeeName').text(data.employeeName);
                        $('#txtEmployeeDesignation').text(data.employeeDesignation);
                        $('#txtDepartmentName').text(data.departmentName);
                        
                        $('#txtCheckInTime').html('<i class="fa-regular fa-clock me-1"></i>' + data.checkInTime);
                        $('#txtPurpose').text(data.purpose);

                        // Image display handling
                        if (data.visitorPhoto) {
                            $('#placeholderPhoto').hide();
                            $('#visitorImg').attr('src', data.visitorPhoto).show();
                        } else {
                            $('#visitorImg').hide();
                            $('#placeholderPhoto').show();
                        }

                        $('#placeholderMessage').hide();
                        $('#detailsContainer').fadeIn();
                    } else {
                        $('#detailsContainer').hide();
                        $('#placeholderMessage').show();
                    }
                });
            }

            // Bind change event
            $('#VisitEntryId').on('change', function() {
                loadVisitDetails($(this).val());
            });

            // Initialize on start if pre-populated (from redirect query string or validation failure)
            var initialVisitId = $('#VisitEntryId').val();
            if (initialVisitId) {
                loadVisitDetails(initialVisitId);
            }
        });
    </script>
}

<style>
    .text-primary { color: #1e3c72 !important; }
    .bg-light { background-color: #f8f9fa !important; }
    .border-primary { border-color: #1e3c72 !important; }
    .border-success { border-color: #198754 !important; }
    .border-warning { border-color: #ffc107 !important; }
    .fs-7 { font-size: 0.85rem; }
</style>
