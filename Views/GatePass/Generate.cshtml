@model VisitorManagementSystem.ViewModels.GeneratePassViewModel
@{
    ViewData["Title"] = "Generate Gate Pass";
}

<div class="container-fluid px-4 py-4">
    <!-- Full Screen Loader -->
    <div id="loadingOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.8); z-index: 9999; justify-content: center; align-items: center; flex-direction: column;">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
        <h4 class="mt-3 text-primary">Processing Pass...</h4>
        <p class="text-muted">Please wait while the pass is being generated.</p>
    </div>
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item text-muted">Security</li>
            <li class="breadcrumb-item active" aria-current="page">Generate Pass</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-address-card me-2 text-primary"></i>Generate Gate Pass</h3>
            <p class="text-muted mb-0">Capture visitor photo and generate an entry pass.</p>
        </div>
        <div>
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary px-4 py-2 rounded-3 fw-semibold">
                <i class="fa-solid fa-arrow-left me-2"></i>Back to Dashboard
            </a>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" onclick="$(this).closest('.alert').remove()"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Visitor Details Card -->
        <div class="col-12 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-id-badge text-primary me-2"></i>Visitor Information</h5>
                </div>
                <div class="card-body p-4 pt-2">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center fw-bold fs-3 me-3 shadow-sm" style="width: 65px; height: 65px; border-radius: 50%;">
                            @Model.Visitor?.FirstName.Substring(0, Math.Min(2, Model.Visitor.FirstName.Length)).ToUpper()
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-0">@Model.Visitor?.FirstName @Model.Visitor?.LastName</h5>
                            <span class="text-muted">@Model.Visitor?.CompanyName</span>
                        </div>
                    </div>
                    
                    <ul class="list-group list-group-flush border-top-0">
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-secondary border-opacity-10">
                            <span class="text-muted"><i class="fa-solid fa-phone me-2"></i>Mobile</span>
                            <strong class="text-dark">@Model.Visitor?.MobileNumber</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-secondary border-opacity-10">
                            <span class="text-muted"><i class="fa-solid fa-envelope me-2"></i>Email</span>
                            <strong class="text-dark text-truncate" style="max-width: 180px;">@Model.Visitor?.Email</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-secondary border-opacity-10">
                            <span class="text-muted"><i class="fa-solid fa-address-card me-2"></i>ID Proof</span>
                            <strong class="text-dark">@Model.Visitor?.IdProofType: @Model.Visitor?.IdProofNumber</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-secondary border-opacity-10">
                            <span class="text-muted"><i class="fa-solid fa-user-tie me-2"></i>Host Employee</span>
                            <strong class="text-dark">@Model.Employee?.FirstName @Model.Employee?.LastName</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-secondary border-opacity-10">
                            <span class="text-muted"><i class="fa-solid fa-briefcase me-2"></i>Purpose</span>
                            <strong class="text-dark">@Model.Purpose</strong>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Camera Capture Card -->
        <div class="col-12 col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-camera text-primary me-2"></i>Photo Capture</h5>
                </div>
                <div class="card-body p-4 pt-2 text-center">
                    
                    <div class="bg-light rounded-4 mb-4 d-flex align-items-center justify-content-center overflow-hidden position-relative" style="height: 350px; border: 2px dashed #dee2e6;">
                        <!-- Video element for live preview -->
                        <video id="videoElement" autoplay playsinline style="width: 100%; height: 100%; object-fit: cover; display: none;"></video>
                        
                        <!-- Canvas element for captured image (hidden) -->
                        <canvas id="canvasElement" style="display: none;"></canvas>
                        
                        <!-- Image element for displaying captured photo -->
                        <img id="photoPreview" style="width: 100%; height: 100%; object-fit: cover; display: none;" />

                        <div id="cameraPlaceholder" class="text-muted text-center">
                            <i class="fa-solid fa-camera fa-3x mb-2 text-secondary opacity-50"></i>
                            <p class="mb-0">Camera preview will appear here</p>
                        </div>
                    </div>

                    <!-- Camera Controls (Pre-Capture) -->
                    <div class="d-flex justify-content-center gap-2 mb-4" id="preCaptureControls">
                        <button type="button" id="btnStartCamera" class="btn btn-primary px-4 rounded-pill">
                            <i class="fa-solid fa-video me-2"></i>Start Camera
                        </button>
                        <button type="button" id="btnCapturePhoto" class="btn btn-warning px-4 rounded-pill" style="display: none;">
                            <i class="fa-solid fa-camera me-2"></i>Capture Photo
                        </button>
                    </div>

                    <!-- Camera Controls (Post-Capture / 3 Buttons) -->
                    <div class="d-flex justify-content-center gap-3 mb-4" id="postCaptureControls" style="display: none !important;">
                        <button type="button" id="btnBack" class="btn btn-secondary px-4 rounded-pill fw-semibold">
                            <i class="fa-solid fa-arrow-left me-2"></i>Back
                        </button>
                        <button type="button" id="btnPrintPass" class="btn btn-info px-4 rounded-pill fw-semibold text-white">
                            <i class="fa-solid fa-print me-2"></i>Print Pass
                        </button>
                        <button type="button" id="btnProceed" class="btn btn-success px-4 rounded-pill fw-bold shadow-sm">
                            <i class="fa-solid fa-check me-2"></i>Proceed
                        </button>
                    </div>

                    <!-- Submission Form (Hidden) -->
                    <form asp-action="Generate" method="post" id="generatePassForm" style="display: none;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="appointmentId" value="@Model.AppointmentId" />
                        <input type="hidden" name="entryRequestId" value="@Model.EntryRequestId" />
                        <input type="hidden" name="photoBase64" id="photoBase64" value="" />
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        body * {
            visibility: hidden;
        }
        #printTemplate, #printTemplate * {
            visibility: visible;
        }
        #printTemplate {
            display: block !important;
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
        }
    }
</style>

<!-- Hidden Gate Pass Print Layout -->
<div id="printTemplate" style="display: none;">
    @{
        var passModel = new VisitorManagementSystem.ViewModels.PassTemplateViewModel
        {
            GatePassNumber = Model.GatePassNumber,
            VisitorName = Model.Visitor?.FirstName + " " + Model.Visitor?.LastName,
            MobileNumber = Model.Visitor?.MobileNumber,
            EmployeeName = Model.Employee?.FirstName + " " + Model.Employee?.LastName,
            Purpose = Model.Purpose,
            VisitDate = DateTime.Now.ToString("dd-MM-yyyy"),
            CheckInTime = "Pending",
            Status = "Pending",
            PhotoPath = "", // Will be injected by JS before printing
            QRCodePath = "data:image/png;base64," + Model.QRCodeBase64
        };
    }
    @await Html.PartialAsync("_PassTemplate", passModel)
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const video = document.getElementById('videoElement');
            const canvas = document.getElementById('canvasElement');
            const photoPreview = document.getElementById('photoPreview');
            const placeholder = document.getElementById('cameraPlaceholder');
            
            const btnStart = document.getElementById('btnStartCamera');
            const btnCapture = document.getElementById('btnCapturePhoto');
            
            const preCaptureControls = document.getElementById('preCaptureControls');
            const postCaptureControls = document.getElementById('postCaptureControls');
            
            const btnBack = document.getElementById('btnBack');
            const btnPrintPass = document.getElementById('btnPrintPass');
            const btnProceed = document.getElementById('btnProceed');
            
            const hiddenPhotoInput = document.getElementById('photoBase64');
            const generateForm = document.getElementById('generatePassForm');
            
            let stream = null;

            // Start Camera
            btnStart.addEventListener('click', async function () {
                try {
                    stream = await navigator.mediaDevices.getUserMedia({ video: true, audio: false });
                    video.srcObject = stream;
                    
                    video.style.display = 'block';
                    placeholder.style.display = 'none';
                    photoPreview.style.display = 'none';
                    
                    btnStart.style.display = 'none';
                    btnCapture.style.display = 'inline-block';
                    
                    postCaptureControls.style.setProperty('display', 'none', 'important');
                    preCaptureControls.style.display = 'flex';
                } catch (err) {
                    console.error("Error accessing camera: ", err);
                    alert("Could not access camera. Please ensure permissions are granted.");
                }
            });

            // Capture Photo
            btnCapture.addEventListener('click', function () {
                if (!stream) return;
                
                // Set canvas size to match video aspect ratio but standard resolution
                canvas.width = 640;
                canvas.height = 480;
                
                // Draw video frame to canvas
                const ctx = canvas.getContext('2d');
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                
                // Get base64 data
                const base64Data = canvas.toDataURL('image/jpeg', 0.8);
                hiddenPhotoInput.value = base64Data;
                
                // Display preview
                photoPreview.src = base64Data;
                photoPreview.style.display = 'block';
                video.style.display = 'none';
                
                // Stop camera stream
                stream.getTracks().forEach(track => track.stop());
                stream = null;
                
                // Update UI buttons
                preCaptureControls.style.display = 'none';
                postCaptureControls.style.setProperty('display', 'flex', 'important');
            });

            // Back Button
            btnBack.addEventListener('click', function () {
                btnStart.click();
            });

            // Print Pass Button
            btnPrintPass.addEventListener('click', function () {
                const printPhoto = document.getElementById('printPhoto');
                if (printPhoto) printPhoto.src = hiddenPhotoInput.value;
                
                // Use browser's native print which is styled via @@media print
                window.print();
            });

            let isSubmitting = false;

            // Proceed Button
            btnProceed.addEventListener('click', function () {
                if (isSubmitting) return;
                isSubmitting = true;
                
                // Disable button to prevent double-submit
                btnProceed.disabled = true;
                btnPrintPass.disabled = true;
                btnBack.disabled = true;
                btnProceed.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Processing...';
                
                // Show overlay
                document.getElementById('loadingOverlay').style.display = 'flex';
                
                generateForm.submit();
            });

            // Clean up stream on page unload
            window.addEventListener('beforeunload', function() {
                if (stream) {
                    stream.getTracks().forEach(track => track.stop());
                }
            });
        });
    </script>
}
