@{
    ViewData["Title"] = "Change Password";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12 col-md-8">
            <h3 class="fw-bold text-dark mb-1">Change Password</h3>
            <p class="text-muted mb-0">Update your account password securely.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-lock text-primary me-2"></i>Security Details</h5>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="ChangePassword" method="post" autocomplete="off">
                        <div class="mb-4">
                            <label for="oldPassword" class="form-label font-weight-bold">Old Password <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="oldPassword" name="oldPassword" placeholder="Enter your current password" required />
                        </div>

                        <div class="mb-4">
                            <label for="newPassword" class="form-label font-weight-bold">
                                New Password <span class="text-danger">*</span>
                                <i class="fa-solid fa-circle-info ms-1 text-muted" data-bs-toggle="tooltip" title="Password must be at least 8 characters long and contain at least one uppercase letter, one lowercase letter, one number, and one special character."></i>
                            </label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword" placeholder="Enter a new password" required />
                            <partial name="_PasswordStrength" model='@("newPassword")' />
                        </div>

                        <div class="mb-4">
                            <label for="confirmPassword" class="form-label font-weight-bold">Confirm New Password <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Re-enter the new password" required />
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top border-slate-100">
                            <a asp-action="Index" asp-controller="Dashboard" class="btn btn-light px-4 rounded-pill fw-semibold">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4 rounded-pill fw-semibold"><i class="fa-solid fa-save me-2"></i>Change Password</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
