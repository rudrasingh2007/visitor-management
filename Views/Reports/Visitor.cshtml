@model VisitorManagementSystem.ViewModels.VisitorReportViewModel
@{
    ViewData["Title"] = "Visitor Report";
}

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item text-muted">Reports & History</li>
            <li class="breadcrumb-item active" aria-current="page">Visitor Report</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-chart-line me-2 text-primary"></i>Visitor Reports</h3>
        <p class="text-muted mb-0">Monitor total registration stats, active vs inactive ratios, and new visitor check-in trends.</p>
    </div>

    <!-- KPI Metrics row -->
    <div class="row g-3 mb-4">
        <!-- Card 1: Total Visitors -->
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white h-100">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="fs-8 text-white-50 text-uppercase fw-bold d-block mb-1">Total Visitors</span>
                        <h3 class="fw-bold mb-0">@Model.TotalVisitors</h3>
                    </div>
                    <div class="fs-1 opacity-25"><i class="fa-solid fa-users"></i></div>
                </div>
            </div>
        </div>

        <!-- Card 2: Active Visitors -->
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-success text-white h-100">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="fs-8 text-white-50 text-uppercase fw-bold d-block mb-1">Active Visitors</span>
                        <h3 class="fw-bold mb-0">@Model.ActiveVisitors</h3>
                    </div>
                    <div class="fs-1 opacity-25"><i class="fa-solid fa-user-check"></i></div>
                </div>
            </div>
        </div>

        <!-- Card 3: Inactive Visitors -->
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-danger text-white h-100">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="fs-8 text-white-50 text-uppercase fw-bold d-block mb-1">Inactive Visitors</span>
                        <h3 class="fw-bold mb-0">@Model.InactiveVisitors</h3>
                    </div>
                    <div class="fs-1 opacity-25"><i class="fa-solid fa-user-xmark"></i></div>
                </div>
            </div>
        </div>

        <!-- Card 4: New Visitors (30d) -->
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-info text-white h-100">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="fs-8 text-white-50 text-uppercase fw-bold d-block mb-1">New (Last 30 Days)</span>
                        <h3 class="fw-bold mb-0">@Model.NewVisitors</h3>
                    </div>
                    <div class="fs-1 opacity-25"><i class="fa-solid fa-user-plus"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-sliders text-primary me-2"></i>Filter Report Data</h6>
            <div class="row g-3">
                <!-- Status Filter -->
                <div class="col-12 col-sm-6 col-md-3">
                    <label class="form-label fw-semibold text-muted small mb-1">Status</label>
                    <select id="statusFilter" class="form-select rounded-2">
                        <option value="">All Statuses</option>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
                <!-- Registration Date Range -->
                <div class="col-12 col-sm-6 col-md-4">
                    <label class="form-label fw-semibold text-muted small mb-1">Registration Start Date</label>
                    <input type="date" id="startDateFilter" class="form-control rounded-2" />
                </div>
                <div class="col-12 col-sm-6 col-md-4">
                    <label class="form-label fw-semibold text-muted small mb-1">Registration End Date</label>
                    <input type="date" id="endDateFilter" class="form-control rounded-2" />
                </div>
            </div>
            <!-- Reset Button -->
            <div class="d-flex justify-content-end mt-3">
                <button type="button" id="btnResetFilters" class="btn btn-sm btn-outline-secondary rounded-2">
                    <i class="fa-solid fa-arrow-rotate-left me-1"></i>Reset Filters
                </button>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle" id="visitorReportTable" style="width:100%;">
                    <thead class="table-light text-muted uppercase fs-7 fw-semibold">
                        <tr>
                            <th>Photo</th>
                            <th>Visitor Name</th>
                            <th>Mobile</th>
                            <th>Email</th>
                            <th>Company</th>
                            <th>Status</th>
                            <th>Registration Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Visitors)
                        {
                            <tr>
                                <td>
                                    <div class="avatar-circle-sm bg-light border rounded shadow-sm d-flex align-items-center justify-content-center overflow-hidden" style="width: 40px; height: 40px;">
                                        @if (!string.IsNullOrEmpty(item.PhotoPath))
                                        {
                                            <img src="@item.PhotoPath" class="img-fluid" style="width:100%; height:100%; object-fit:cover;" alt="Visitor" />
                                        }
                                        else
                                        {
                                            <i class="fa-solid fa-user text-muted"></i>
                                        }
                                    </div>
                                </td>
                                <td class="fw-semibold text-dark">@item.FirstName @item.LastName</td>
                                <td>@item.MobileNumber</td>
                                <td class="text-truncate" style="max-width: 180px;">@item.Email</td>
                                <td>@(item.CompanyName ?? "-")</td>
                                <td>
                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge bg-success-subtle text-success px-2 py-1 fs-8 rounded-pill">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-2 py-1 fs-8 rounded-pill">Inactive</span>
                                    }
                                </td>
                                <td class="created-date" data-date="@item.CreatedDate.ToLocalTime().ToString("yyyy-MM-dd")" data-order="@item.CreatedDate.ToString("yyyyMMddHHmmss")">
                                    @item.CreatedDate.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize DataTable
            var table = $('#visitorReportTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search report..."
                },
                "order": [[6, "desc"]], // Default order by created date desc
                "buttons": [
                    {
                        extend: 'excel',
                        className: 'btn btn-sm btn-success me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-excel me-1"></i> Excel',
                        exportOptions: { columns: [1, 2, 3, 4, 5, 6] }
                    },
                    {
                        extend: 'pdf',
                        className: 'btn btn-sm btn-danger me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-pdf me-1"></i> PDF',
                        exportOptions: { columns: [1, 2, 3, 4, 5, 6] }
                    },
                    {
                        extend: 'print',
                        className: 'btn btn-sm btn-secondary text-white rounded-2',
                        text: '<i class="fa-solid fa-print me-1"></i> Print Report',
                        exportOptions: { columns: [1, 2, 3, 4, 5, 6] }
                    }
                ],
                "dom": "<'row mb-3'<'col-sm-12 col-md-6'lB><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            // Status Filter Dropdown
            $('#statusFilter').on('change', function() {
                var val = $(this).val();
                table.column(5).search(val ? '^\\s*' + val + '\\s*$' : '', true, false).draw();
            });

            // Custom Date Range filter
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    var startDateStr = $('#startDateFilter').val(); // YYYY-MM-DD
                    var endDateStr = $('#endDateFilter').val(); // YYYY-MM-DD
                    
                    var rowDateStr = $(table.row(dataIndex).node()).find('td.created-date').attr('data-date');
                    if (!rowDateStr) return true;
                    
                    var rowDate = new Date(rowDateStr);
                    rowDate.setHours(0,0,0,0);

                    if (startDateStr) {
                        var startDate = new Date(startDateStr);
                        startDate.setHours(0,0,0,0);
                        if (rowDate < startDate) return false;
                    }
                    if (endDateStr) {
                        var endDate = new Date(endDateStr);
                        endDate.setHours(0,0,0,0);
                        if (rowDate > endDate) return false;
                    }
                    return true;
                }
            );

            // Re-draw when dates change
            $('#startDateFilter, #endDateFilter').on('change', function() {
                table.draw();
            });

            // Reset Filters
            $('#btnResetFilters').click(function() {
                $('#statusFilter').val('');
                $('#startDateFilter').val('');
                $('#endDateFilter').val('');
                
                table.column(5).search('');
                table.draw();
            });
        });
    </script>
}

<style>
    .fs-7 { font-size: 0.85rem; }
    .fs-8 { font-size: 0.75rem; }
</style>
