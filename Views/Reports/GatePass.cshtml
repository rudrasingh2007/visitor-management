@model VisitorManagementSystem.ViewModels.GatePassReportViewModel
@{
    ViewData["Title"] = "Gate Pass Report";
}

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item text-muted">Reports & History</li>
            <li class="breadcrumb-item active" aria-current="page">Gate Pass Report</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-ticket me-2 text-warning text-primary"></i>Gate Pass Reports</h3>
        <p class="text-muted mb-0">Monitor issued visitor badges, dynamic expiry distributions, and closed pass status logs.</p>
    </div>

    <!-- KPI Metrics row -->
    <div class="row g-3 mb-4">
        <!-- Total Gate Passes -->
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white h-100">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="fs-8 text-white-50 text-uppercase fw-bold d-block mb-1">Total Gate Passes</span>
                        <h3 class="fw-bold mb-0">@Model.TotalGatePasses</h3>
                    </div>
                    <div class="fs-1 opacity-25"><i class="fa-solid fa-passport"></i></div>
                </div>
            </div>
        </div>

        <!-- Active Gate Passes -->
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-success text-white h-100">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="fs-8 text-white-50 text-uppercase fw-bold d-block mb-1">Active Gate Passes</span>
                        <h3 class="fw-bold mb-0">@Model.ActiveGatePasses</h3>
                    </div>
                    <div class="fs-1 opacity-25"><i class="fa-solid fa-check-double"></i></div>
                </div>
            </div>
        </div>

        <!-- Closed Gate Passes -->
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-secondary text-white h-100">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="fs-8 text-white-50 text-uppercase fw-bold d-block mb-1">Closed Gate Passes</span>
                        <h3 class="fw-bold mb-0">@Model.ClosedGatePasses</h3>
                    </div>
                    <div class="fs-1 opacity-25"><i class="fa-solid fa-lock"></i></div>
                </div>
            </div>
        </div>

        <!-- Expired Gate Passes -->
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-danger text-white h-100">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="fs-8 text-white-50 text-uppercase fw-bold d-block mb-1">Expired Gate Passes</span>
                        <h3 class="fw-bold mb-0">@Model.ExpiredGatePasses</h3>
                    </div>
                    <div class="fs-1 opacity-25"><i class="fa-solid fa-clock-rotate-left"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters Card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-sliders text-primary me-2"></i>Filter Report Data</h6>
            <div class="row g-3">
                <!-- Status Filter -->
                <div class="col-12 col-sm-6 col-md-3">
                    <label class="form-label fw-semibold text-muted small mb-1">Status</label>
                    <select id="statusFilter" class="form-select rounded-2">
                        <option value="">All Statuses</option>
                        <option value="Approved">Approved</option>
                        <option value="Checked In">Checked In</option>
                        <option value="Checked Out">Checked Out</option>
                        <option value="Expired">Expired</option>
                    </select>
                </div>
                <!-- Visitor Filter -->
                <div class="col-12 col-sm-6 col-md-3">
                    <label class="form-label fw-semibold text-muted small mb-1">Visitor</label>
                    <select id="visitorFilter" class="form-select rounded-2" asp-items="ViewBag.VisitorsList">
                        <option value="">All Visitors</option>
                    </select>
                </div>
                <!-- Employee Filter -->
                <div class="col-12 col-sm-6 col-md-3">
                    <label class="form-label fw-semibold text-muted small mb-1">Employee Name</label>
                    <select id="employeeFilter" class="form-select rounded-2" asp-items="ViewBag.EmployeesList">
                        <option value="">All Employees</option>
                    </select>
                </div>
                <!-- Date Range -->
                <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                    <label class="form-label fw-semibold text-muted small mb-1">Start Date</label>
                    <input type="date" id="startDateFilter" class="form-control rounded-2" />
                </div>
                <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                    <label class="form-label fw-semibold text-muted small mb-1">End Date</label>
                    <input type="date" id="endDateFilter" class="form-control rounded-2" />
                </div>
            </div>
            <!-- Reset Button -->
            <div class="d-flex justify-content-end mt-3">
                <button type="button" id="btnResetFilters" class="btn btn-sm btn-outline-secondary rounded-2">
                    <i class="fa-solid fa-arrow-rotate-left me-1"></i>Reset Filters
                </button>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle" id="gatePassReportTable" style="width:100%;">
                    <thead class="table-light text-muted uppercase fs-7 fw-semibold">
                        <tr>
                            <th>Gate Pass Number</th>
                            <th>Visitor Name</th>
                            <th>Employee Name</th>
                            <th>Check-In Time</th>
                            <th>Check-Out Time</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.GatePasses)
                        {
                            var isExpired = (item.Status == "Approved" || item.Status == "Checked In" || item.Status == "Active") && DateTime.UtcNow > item.ExpiryDateTime;
                            var currentStatus = isExpired ? "Expired" : item.Status;

                            <tr>
                                <td class="fw-bold text-dark"><i class="fa-solid fa-ticket text-primary-emphasis me-1"></i>@item.GatePassNumber</td>
                                <td class="fw-semibold">@(item.Visitor != null ? $"{item.Visitor.FirstName} {item.Visitor.LastName}" : "Unknown")</td>
                                <td>@(item.Employee != null ? $"{item.Employee.FirstName} {item.Employee.LastName}" : "Unknown")</td>
                                <td class="issue-date" data-date="@(item.VisitEntry?.CheckInTime != null ? item.VisitEntry.CheckInTime.Value.ToLocalTime().ToString("yyyy-MM-dd") : "")" data-order="@(item.VisitEntry?.CheckInTime != null ? item.VisitEntry.CheckInTime.Value.ToString("yyyyMMddHHmmss") : "")">
                                    @(item.VisitEntry?.CheckInTime != null ? item.VisitEntry.CheckInTime.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt") : "N/A")
                                </td>
                                <td>
                                    @(item.VisitEntry?.CheckOutTime != null ? item.VisitEntry.CheckOutTime.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt") : "N/A")
                                </td>
                                <td>
                                    @if (currentStatus == "Approved")
                                    {
                                        <span class="badge bg-primary-subtle text-primary px-3 py-2 fs-8 rounded-pill"><i class="fa-solid fa-circle-check me-1"></i>Approved</span>
                                    }
                                    else if (currentStatus == "Checked In")
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 fs-8 rounded-pill"><i class="fa-solid fa-circle-play me-1"></i>Checked In</span>
                                    }
                                    else if (currentStatus == "Checked Out" || currentStatus == "Closed")
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-3 py-2 fs-8 rounded-pill"><i class="fa-solid fa-circle-stop me-1"></i>Checked Out</span>
                                    }
                                    else if (currentStatus == "Expired")
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 fs-8 rounded-pill"><i class="fa-solid fa-circle-exclamation me-1"></i>Expired</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-3 py-2 fs-8 rounded-pill">@currentStatus</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize DataTable
            var table = $('#gatePassReportTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search report..."
                },
                "order": [[3, "desc"]], // Default order by Check-In Time desc
                "buttons": [
                    {
                        extend: 'excel',
                        className: 'btn btn-sm btn-success me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-excel me-1"></i> Excel',
                        exportOptions: { columns: [0, 1, 2, 3, 4, 5] }
                    },
                    {
                        extend: 'pdf',
                        className: 'btn btn-sm btn-danger me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-pdf me-1"></i> PDF',
                        exportOptions: { columns: [0, 1, 2, 3, 4, 5] }
                    },
                    {
                        extend: 'print',
                        className: 'btn btn-sm btn-secondary text-white rounded-2',
                        text: '<i class="fa-solid fa-print me-1"></i> Print Report',
                        exportOptions: { columns: [0, 1, 2, 3, 4, 5] }
                    }
                ],
                "dom": "<'row mb-3'<'col-sm-12 col-md-6'lB><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            // Status Filter Dropdown
            $('#statusFilter').on('change', function() {
                var val = $(this).val();
                table.column(5).search(val ? '^\\s*' + val + '\\s*$' : '', true, false).draw();
            });

            // Visitor Filter Dropdown
            $('#visitorFilter').on('change', function() {
                var val = $(this).val();
                table.column(1).search(val ? '^\\s*' + val + '\\s*$' : '', true, false).draw();
            });

            // Employee Filter Dropdown
            $('#employeeFilter').on('change', function() {
                var val = $(this).val();
                table.column(2).search(val ? '^\\s*' + val + '\\s*$' : '', true, false).draw();
            });

            // Custom Date Range filter
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    var startDateStr = $('#startDateFilter').val(); // YYYY-MM-DD
                    var endDateStr = $('#endDateFilter').val(); // YYYY-MM-DD
                    
                    var rowDateStr = $(table.row(dataIndex).node()).find('td.issue-date').attr('data-date');
                    if (!rowDateStr) return true;
                    
                    var rowDate = new Date(rowDateStr);
                    rowDate.setHours(0,0,0,0);

                    if (startDateStr) {
                        var startDate = new Date(startDateStr);
                        startDate.setHours(0,0,0,0);
                        if (rowDate < startDate) return false;
                    }
                    if (endDateStr) {
                        var endDate = new Date(endDateStr);
                        endDate.setHours(0,0,0,0);
                        if (rowDate > endDate) return false;
                    }
                    return true;
                }
            );

            // Re-draw when dates change
            $('#startDateFilter, #endDateFilter').on('change', function() {
                table.draw();
            });

            // Reset Filters
            $('#btnResetFilters').click(function() {
                $('#statusFilter').val('');
                $('#visitorFilter').val('');
                $('#employeeFilter').val('');
                $('#startDateFilter').val('');
                $('#endDateFilter').val('');
                
                table.column(5).search('');
                table.column(1).search('');
                table.column(2).search('');
                table.draw();
            });
        });
    </script>
}

<style>
    .fs-7 { font-size: 0.85rem; }
    .fs-8 { font-size: 0.75rem; }
</style>
