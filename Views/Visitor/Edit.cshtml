@model VisitorManagementSystem.ViewModels.VisitorViewModel
@{
    ViewData["Title"] = "Edit Visitor";
}

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Visitor List</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit Visitor</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-user-pen me-2 text-primary"></i>Edit Visitor</h3>
        <p class="text-muted mb-0">Modify information details for an existing visitor.</p>
    </div>

    <div class="row">
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" autocomplete="off">
                        @Html.AntiForgeryToken()
                        
                        <input type="hidden" asp-for="VisitorId" />
                        <input type="hidden" asp-for="PhotoPath" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <!-- Basic Information -->
                        <h6 class="fw-bold text-primary mb-3">Basic Details</h6>
                        <div class="row">
                            <!-- First Name -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label fw-semibold text-dark">First Name <span class="text-danger">*</span></label>
                                <input asp-for="FirstName" class="form-control rounded-2 p-2" required />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>

                            <!-- Last Name -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label fw-semibold text-dark">Last Name</label>
                                <input asp-for="LastName" class="form-control rounded-2 p-2" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Gender Dropdown -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Gender" class="form-label fw-semibold text-dark">Gender <span class="text-danger">*</span></label>
                                <select asp-for="Gender" class="form-select rounded-2 p-2" required>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small"></span>
                            </div>

                            <!-- Company Name (Optional) -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="CompanyName" class="form-label fw-semibold text-dark">Company Name <span class="text-muted small">(Optional)</span></label>
                                <input asp-for="CompanyName" class="form-control rounded-2 p-2" />
                                <span asp-validation-for="CompanyName" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="text-muted border-secondary opacity-10 my-4" />

                        <!-- Contact & Verification -->
                        <h6 class="fw-bold text-primary mb-3">Contact & Verification Details</h6>
                        <div class="row">
                            <!-- Mobile Number -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="MobileNumber" class="form-label fw-semibold text-dark">Mobile Number <span class="text-danger">*</span></label>
                                <input asp-for="MobileNumber" class="form-control rounded-2 p-2" required />
                                <span asp-validation-for="MobileNumber" class="text-danger small"></span>
                            </div>

                            <!-- Email Address -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-semibold text-dark">Email Address <span class="text-danger">*</span></label>
                                <input asp-for="Email" type="email" class="form-control rounded-2 p-2" required />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <!-- ID Proof Type Dropdown -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="IdProofType" class="form-label fw-semibold text-dark">ID Proof Type <span class="text-danger">*</span></label>
                                <select asp-for="IdProofType" class="form-select rounded-2 p-2" required>
                                    <option value="Aadhaar Card">Aadhaar Card</option>
                                    <option value="PAN Card">PAN Card</option>
                                    <option value="Driving License">Driving License</option>
                                    <option value="Passport">Passport</option>
                                    <option value="Voter ID">Voter ID</option>
                                </select>
                                <span asp-validation-for="IdProofType" class="text-danger small"></span>
                            </div>

                            <!-- ID Proof Number -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="IdProofNumber" class="form-label fw-semibold text-dark">ID Proof Number <span class="text-danger">*</span></label>
                                <input asp-for="IdProofNumber" class="form-control rounded-2 p-2" required />
                                <span asp-validation-for="IdProofNumber" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Status Dropdown -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Status" class="form-label fw-semibold text-dark">Status <span class="text-danger">*</span></label>
                                <select asp-for="Status" class="form-select rounded-2 p-2" required>
                                    <option value="Active">Active</option>
                                    <option value="Inactive">Inactive</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="text-muted border-secondary opacity-10 my-4" />

                        <!-- Address Info -->
                        <h6 class="fw-bold text-primary mb-3">Address Information</h6>
                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-semibold text-dark">Address Details <span class="text-danger">*</span></label>
                            <input asp-for="Address" class="form-control rounded-2 p-2" required />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <!-- City -->
                            <div class="col-md-6 mb-4">
                                <label asp-for="City" class="form-label fw-semibold text-dark">City <span class="text-danger">*</span></label>
                                <input asp-for="City" class="form-control rounded-2 p-2" required />
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>

                            <!-- State -->
                            <div class="col-md-6 mb-4">
                                <label asp-for="State" class="form-label fw-semibold text-dark">State <span class="text-danger">*</span></label>
                                <input asp-for="State" class="form-control rounded-2 p-2" required />
                                <span asp-validation-for="State" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4 py-2 fw-semibold rounded-2 shadow-sm">
                                <i class="fa-solid fa-save me-2"></i>Update Visitor
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-2">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
