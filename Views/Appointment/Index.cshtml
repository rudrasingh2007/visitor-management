@model IEnumerable<VisitorManagementSystem.Models.AppointmentMaster>
@{
    ViewData["Title"] = "Appointment List";
}

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item text-muted">Appointment Management</li>
            <li class="breadcrumb-item active" aria-current="page">Appointment List</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-calendar-check me-2 text-primary"></i>Appointment Master</h3>
            <p class="text-muted mb-0">Track and manage scheduled appointments, approve requests, and maintain visitor schedules.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary px-4 py-2 fw-semibold shadow-sm">
                <i class="fa-solid fa-calendar-plus me-2"></i>Schedule Appointment
            </a>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" onclick="$(this).closest('.alert').remove()"></button>
        </div>
    }

    <!-- Advanced Filters Card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-sliders text-primary me-2"></i>Filter Records</h6>
            <div class="row g-3">
                <!-- Status Filter -->
                <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                    <label class="form-label fw-semibold text-muted small mb-1">Status</label>
                    <select id="statusFilter" class="form-select rounded-2">
                        <option value="">All Statuses</option>
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="Rejected">Rejected</option>
                        <option value="Cancelled">Cancelled</option>
                        <option value="Completed">Completed</option>
                    </select>
                </div>
                <!-- Department Filter -->
                <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                    <label class="form-label fw-semibold text-muted small mb-1">Department</label>
                    <select id="deptFilter" class="form-select rounded-2" asp-items="ViewBag.DepartmentsList">
                        <option value="">All Departments</option>
                    </select>
                </div>
                <!-- Visitor Filter -->
                <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                    <label class="form-label fw-semibold text-muted small mb-1">Visitor</label>
                    <select id="visitorFilter" class="form-select rounded-2" asp-items="ViewBag.VisitorsList">
                        <option value="">All Visitors</option>
                    </select>
                </div>
                <!-- Employee Filter -->
                <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                    <label class="form-label fw-semibold text-muted small mb-1">Employee Host</label>
                    <select id="employeeFilter" class="form-select rounded-2" asp-items="ViewBag.EmployeesList">
                        <option value="">All Employees</option>
                    </select>
                </div>
                <!-- Date Range: Start -->
                <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                    <label class="form-label fw-semibold text-muted small mb-1">Start Date</label>
                    <input type="date" id="startDateFilter" class="form-control rounded-2" />
                </div>
                <!-- Date Range: End -->
                <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                    <label class="form-label fw-semibold text-muted small mb-1">End Date</label>
                    <input type="date" id="endDateFilter" class="form-control rounded-2" />
                </div>
            </div>
            <!-- Reset Button -->
            <div class="d-flex justify-content-end mt-3">
                <button type="button" id="btnResetFilters" class="btn btn-sm btn-outline-secondary rounded-2">
                    <i class="fa-solid fa-arrow-rotate-left me-1"></i>Reset Filters
                </button>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle" id="appointmentsTable" style="width: 100%;">
                    <thead class="table-light text-muted uppercase fs-7 fw-semibold">
                        <tr>
                            <th>Visitor Name</th>
                            <th>Department</th>
                            <th>Employee Name</th>
                            <th>Date & Time</th>
                            <th>Status</th>
                            <th class="text-end" style="min-width: 100px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@(item.Visitor != null ? $"{item.Visitor.FirstName} {item.Visitor.LastName}" : "Unknown Visitor")</td>
                                <td><span class="badge bg-secondary-subtle text-secondary px-2 py-1 fs-8">@(item.Department?.DepartmentName ?? "No Dept")</span></td>
                                <td>@(item.Employee != null ? $"{item.Employee.FirstName} {item.Employee.LastName}" : "Unknown Employee")</td>
                                <td class="app-date" data-date="@item.AppointmentDate.ToString("yyyy-MM-dd")" data-order="@item.AppointmentDate.ToString("yyyyMMdd")@item.AppointmentTime.ToString("hhmmss")">
                                    @item.AppointmentDate.ToString("dd MMM yyyy") at @DateTime.Today.Add(item.AppointmentTime).ToString("hh:mm tt")
                                </td>
                                <td>
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning-subtle text-warning px-3 py-2 fs-8 rounded-pill"><i class="fa-solid fa-clock me-1"></i>Pending</span>
                                    }
                                    else if (item.Status == "Approved")
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 fs-8 rounded-pill"><i class="fa-solid fa-circle-check me-1"></i>Approved</span>
                                    }
                                    else if (item.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 fs-8 rounded-pill"><i class="fa-solid fa-circle-xmark me-1"></i>Rejected</span>
                                    }
                                    else if (item.Status == "Cancelled")
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-3 py-2 fs-8 rounded-pill"><i class="fa-solid fa-ban me-1"></i>Cancelled</span>
                                    }
                                    else if (item.Status == "Completed")
                                    {
                                        <span class="badge bg-primary-subtle text-primary px-3 py-2 fs-8 rounded-pill"><i class="fa-solid fa-check-double me-1"></i>Completed</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <!-- View Details -->
                                    <a asp-action="Details" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-info me-1 rounded-2" title="View Details">
                                        <i class="fa-solid fa-circle-info"></i>
                                    </a>
                                    <!-- Edit -->
                                    <a asp-action="Edit" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-primary rounded-2" title="Edit Appointment">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize DataTable
            var table = $('#appointmentsTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search appointments..."
                },
                "order": [[3, "desc"]], // Default sort by Date & Time desc
                "buttons": [
                    {
                        extend: 'excel',
                        className: 'btn btn-sm btn-outline-success me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-excel me-1"></i> Excel',
                        exportOptions: { columns: [0, 1, 2, 3, 4] }
                    },
                    {
                        extend: 'pdf',
                        className: 'btn btn-sm btn-outline-danger me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-pdf me-1"></i> PDF',
                        exportOptions: { columns: [0, 1, 2, 3, 4] }
                    },
                    {
                        extend: 'print',
                        className: 'btn btn-sm btn-outline-secondary rounded-2',
                        text: '<i class="fa-solid fa-print me-1"></i> Print',
                        exportOptions: { columns: [0, 1, 2, 3, 4] }
                    }
                ],
                "dom": "<'row mb-3'<'col-sm-12 col-md-6'lB><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            // Status Filter Dropdown (Column index 4)
            $('#statusFilter').on('change', function() {
                var val = $(this).val();
                table.column(4).search(val ? '^\\s*' + val + '\\s*$' : '', true, false).draw();
            });

            // Department Filter Dropdown (Column index 1)
            $('#deptFilter').on('change', function() {
                var val = $(this).val();
                table.column(1).search(val ? '^\\s*' + val + '\\s*$' : '', true, false).draw();
            });

            // Visitor Filter Dropdown (Column index 0)
            $('#visitorFilter').on('change', function() {
                var val = $(this).val();
                table.column(0).search(val ? '^\\s*' + val + '\\s*$' : '', true, false).draw();
            });

            // Employee Filter Dropdown (Column index 2)
            $('#employeeFilter').on('change', function() {
                var val = $(this).val();
                table.column(2).search(val ? '^\\s*' + val + '\\s*$' : '', true, false).draw();
            });

            // Date range filter logic using $.fn.dataTable.ext.search
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    var startDateInput = $('#startDateFilter').val();
                    var endDateInput = $('#endDateFilter').val();
                    
                    if (!startDateInput && !endDateInput) {
                        return true;
                    }
                    
                    var rowDateStr = $(table.row(dataIndex).node()).find('td.app-date').attr('data-date');
                    if (!rowDateStr) {
                        return true;
                    }
                    
                    var rowDate = new Date(rowDateStr);
                    rowDate.setHours(0,0,0,0);
                    
                    if (startDateInput) {
                        var startDate = new Date(startDateInput);
                        startDate.setHours(0,0,0,0);
                        if (rowDate < startDate) {
                            return false;
                        }
                    }
                    
                    if (endDateInput) {
                        var endDate = new Date(endDateInput);
                        endDate.setHours(0,0,0,0);
                        if (rowDate > endDate) {
                            return false;
                        }
                    }
                    
                    return true;
                }
            );

            // Re-draw table when date range changes
            $('#startDateFilter, #endDateFilter').on('change', function() {
                table.draw();
            });

            // Reset filters logic
            $('#btnResetFilters').click(function() {
                $('#statusFilter').val('');
                $('#deptFilter').val('');
                $('#visitorFilter').val('');
                $('#employeeFilter').val('');
                $('#startDateFilter').val('');
                $('#endDateFilter').val('');
                
                table.columns().search('').draw();
                table.draw();
            });
        });
    </script>
}

<style>
    .bg-warning-subtle { background-color: rgba(255, 193, 7, 0.1) !important; }
    .bg-success-subtle { background-color: rgba(25, 135, 84, 0.1) !important; }
    .bg-danger-subtle { background-color: rgba(220, 53, 69, 0.1) !important; }
    .bg-secondary-subtle { background-color: rgba(108, 117, 125, 0.1) !important; }
    .bg-primary-subtle { background-color: rgba(30, 60, 114, 0.1) !important; }
    .text-primary { color: #1e3c72 !important; }
    .fs-7 { font-size: 0.85rem; }
    .fs-8 { font-size: 0.75rem; }
    .dataTables_filter input {
        border-radius: 6px;
        border: 1px solid #ced4da;
        padding: 6px 12px;
    }
    .dataTables_length select {
        border-radius: 6px;
        border: 1px solid #ced4da;
        padding: 6px 12px;
    }
</style>
