@model VisitorManagementSystem.ViewModels.PassTemplateViewModel

<div style="font-family: Arial, sans-serif; width: 380px; height: 240px; margin: 0 auto; border: 2px solid #333; padding: 10px 15px; text-align: left; background: white; box-sizing: border-box; border-radius: 8px; position: relative;">
    <!-- Header -->
    <div style="text-align: center; border-bottom: 2px solid #333; padding-bottom: 5px; margin-bottom: 10px;">
        <h3 style="margin: 0; color: #333; letter-spacing: 1px; font-size: 16px;">VISITOR PASS</h3>
    </div>

    <!-- Body Container -->
    <div style="display: flex; align-items: stretch; justify-content: space-between; height: calc(100% - 40px);">
        
        <!-- Left: Photo -->
        <div style="flex: 0 0 auto; padding-right: 15px; display: flex; align-items: center;">
            <img id="printPhoto" src="@(string.IsNullOrEmpty(Model.PhotoPath) ? "/img/default_user.svg" : Model.PhotoPath)" style="width: 75px; height: 75px; object-fit: @(string.IsNullOrEmpty(Model.PhotoPath) ? "contain" : "cover"); padding: @(string.IsNullOrEmpty(Model.PhotoPath) ? "10px" : "0"); border: 1px solid #999; border-radius: 4px; background-color: #f8f9fa;" />
        </div>

        <!-- Middle: Details -->
        <div style="flex: 1 1 auto; font-size: 12px; color: #333; border-left: 1px solid #ddd; padding-left: 15px; display: flex; flex-direction: column; justify-content: center;">
            @if (!string.IsNullOrWhiteSpace(Model.VisitorName))
            {
                <p style="margin: 0 0 4px 0;"><strong>Name:</strong> @Model.VisitorName</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.MobileNumber))
            {
                <p style="margin: 0 0 4px 0;"><strong>Mobile:</strong> @Model.MobileNumber</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.EmployeeName))
            {
                <p style="margin: 0 0 4px 0;"><strong>Host:</strong> @Model.EmployeeName</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.GatePassNumber))
            {
                <p style="margin: 0 0 4px 0;"><strong>Pass No:</strong> @Model.GatePassNumber</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.VisitDate) || !string.IsNullOrWhiteSpace(Model.CheckInTime))
            {
                <p style="margin: 0 0 4px 0;"><strong>Date/Time:</strong> @Model.VisitDate @Model.CheckInTime</p>
            }
        </div>

        <!-- Right: QR Code -->
        <div style="flex: 0 0 auto; padding-left: 15px; border-left: 1px solid #ddd; display: flex; align-items: center;">
            @if (!string.IsNullOrEmpty(Model.QRCodePath))
            {
                <img src="@Model.QRCodePath" style="width: 70px; height: 70px;" />
            }
        </div>

    </div>
</div>
