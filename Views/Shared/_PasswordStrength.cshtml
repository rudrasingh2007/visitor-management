@model string
<!-- @Model is the target input ID -->
<div class="mt-2" id="ps-container-@Model">
    <div class="d-flex gap-1 mb-1">
        <div class="ps-block flex-fill rounded" style="height: 6px; background-color: #e9ecef;" id="ps-block-len-@Model" title="8+ Characters"></div>
        <div class="ps-block flex-fill rounded" style="height: 6px; background-color: #e9ecef;" id="ps-block-upper-@Model" title="Uppercase Letter"></div>
        <div class="ps-block flex-fill rounded" style="height: 6px; background-color: #e9ecef;" id="ps-block-lower-@Model" title="Lowercase Letter"></div>
        <div class="ps-block flex-fill rounded" style="height: 6px; background-color: #e9ecef;" id="ps-block-num-@Model" title="Number"></div>
        <div class="ps-block flex-fill rounded" style="height: 6px; background-color: #e9ecef;" id="ps-block-spec-@Model" title="Special Character"></div>
    </div>
    <div class="small text-muted ps-text" style="font-size: 0.75rem;" id="ps-text-@Model">Password strength</div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const inputId = '@Model';
        const input = document.getElementById(inputId);
        if (!input) return;

        const blockLen = document.getElementById('ps-block-len-' + inputId);
        const blockUpper = document.getElementById('ps-block-upper-' + inputId);
        const blockLower = document.getElementById('ps-block-lower-' + inputId);
        const blockNum = document.getElementById('ps-block-num-' + inputId);
        const blockSpec = document.getElementById('ps-block-spec-' + inputId);
        const textStr = document.getElementById('ps-text-' + inputId);

        input.addEventListener('input', function () {
            const val = input.value;
            let score = 0;

            const hasLen = val.length >= 8;
            const hasUpper = /[A-Z]/.test(val);
            const hasLower = /[a-z]/.test(val);
            const hasNum = /\d/.test(val);
            const hasSpec = /[@@$!%*?&]/.test(val);

            // Update blocks visually
            blockLen.style.backgroundColor = hasLen ? '#198754' : '#e9ecef';
            blockUpper.style.backgroundColor = hasUpper ? '#198754' : '#e9ecef';
            blockLower.style.backgroundColor = hasLower ? '#198754' : '#e9ecef';
            blockNum.style.backgroundColor = hasNum ? '#198754' : '#e9ecef';
            blockSpec.style.backgroundColor = hasSpec ? '#198754' : '#e9ecef';

            score = [hasLen, hasUpper, hasLower, hasNum, hasSpec].filter(Boolean).length;

            if (score === 0) {
                textStr.textContent = 'Password strength';
                textStr.className = 'small text-muted ps-text';
            } else if (score < 3) {
                textStr.textContent = 'Weak';
                textStr.className = 'small text-danger ps-text';
            } else if (score < 5) {
                textStr.textContent = 'Medium';
                textStr.className = 'small text-warning ps-text';
            } else {
                textStr.textContent = 'Strong';
                textStr.className = 'small text-success ps-text';
            }
        });
    });
</script>
