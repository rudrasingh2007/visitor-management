@model IEnumerable<VisitorManagementSystem.Models.EntryRequestMaster>
@{
    ViewData["Title"] = "Pending Visitor Requests";
}

<div class="container-fluid px-4 py-4">
    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-hourglass-half me-2 text-warning"></i>Pending Visitor Requests</h3>
        <p class="text-muted mb-0">Review and approve or reject entry requests for visitors waiting at the gate.</p>
    </div>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="fa-solid fa-circle-exmark me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-warning rounded-3 border-0">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>@ViewBag.Error
            </div>
        }
        else if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="bg-light d-inline-flex p-3 rounded-circle text-muted mb-3">
                    <i class="fa-solid fa-folder-open fa-2x"></i>
                </div>
                <h5 class="fw-bold text-dark mb-1">No Pending Requests</h5>
                <p class="text-muted small">You don't have any pending visitor entry requests at the moment.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="width: 100%;">
                    <thead class="table-light text-muted fs-8 fw-semibold uppercase border-bottom-0">
                        <tr>
                            <th>Request Time</th>
                            <th>Visitor Name</th>
                            <th>Mobile Number</th>
                            <th>Company Name</th>
                            <th>Purpose</th>
                            <th style="min-width: 320px;">Actions & Remarks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in Model)
                        {
                            <tr>
                                <td class="small text-dark">
                                    @request.RequestDateTime.ToAppLocalTime().ToString("dd MMM yyyy")
                                    <span class="text-muted d-block fs-8">@request.RequestDateTime.ToAppLocalTime().ToString("hh:mm tt")</span>
                                </td>
                                <td class="fw-semibold text-dark">@(request.Visitor != null ? $"{request.Visitor.FirstName} {request.Visitor.LastName}" : "-")</td>
                                <td class="text-muted small">@(request.Visitor?.MobileNumber ?? "-")</td>
                                <td class="small text-dark">@(request.Visitor?.CompanyName ?? "N/A")</td>
                                <td class="small text-muted">@request.Purpose</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <button type="button" class="btn btn-sm btn-success rounded-pill px-3 d-flex align-items-center gap-1 btn-process-request" data-id="@request.EntryRequestId" data-action="Approve">
                                            <i class="fa-solid fa-check"></i>Approve
                                        </button>
                                        <button type="button" class="btn btn-sm btn-danger rounded-pill px-3 d-flex align-items-center gap-1 btn-process-request" data-id="@request.EntryRequestId" data-action="Reject">
                                            <i class="fa-solid fa-xmark"></i>Reject
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Approval/Rejection Modal -->
<div class="modal fade" id="remarksModal" tabindex="-1" aria-labelledby="remarksModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="remarksModalLabel">Process Entry Request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="remarksForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="modalRequestId" value="" />
                <div class="modal-body py-3">
                    <p class="text-muted small mb-3">Please provide any remarks/notes for this action.</p>
                    <div class="mb-3">
                        <label for="approvalRemarks" class="form-label fw-semibold text-secondary">Remarks <span class="text-danger">*</span></label>
                        <textarea class="form-control rounded-3" id="approvalRemarks" name="approvalRemarks" rows="3" placeholder="Enter remarks here..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="submitModalBtn" class="btn btn-success rounded-pill px-4">Confirm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.btn-process-request').on('click', function () {
                var id = $(this).data('id');
                var action = $(this).data('action');
                
                $('#modalRequestId').val(id);
                $('#remarksForm').attr('action', '/EntryRequest/' + action);
                
                if (action === 'Approve') {
                    $('#remarksModalLabel').text('Approve Entry Request');
                    $('#submitModalBtn').removeClass('btn-danger').addClass('btn-success').text('Approve');
                    $('#approvalRemarks').attr('placeholder', 'Enter approval remarks (e.g., Please proceed to meet)...');
                } else {
                    $('#remarksModalLabel').text('Reject Entry Request');
                    $('#submitModalBtn').removeClass('btn-success').addClass('btn-danger').text('Reject');
                    $('#approvalRemarks').attr('placeholder', 'Enter reason for rejection...');
                }
                
                $('#approvalRemarks').val('');
                
                var myModal = new bootstrap.Modal(document.getElementById('remarksModal'));
                myModal.show();
            });
        });
    </script>
}
