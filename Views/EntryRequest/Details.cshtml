@model VisitorManagementSystem.Models.EntryRequestMaster
@{
    ViewData["Title"] = "Entry Request Details";
    var gp = Model.GatePasses.FirstOrDefault();
    var gatePassNumber = gp?.GatePassNumber ?? "Pending Generation";
    var checkInTimeText = gp?.VisitEntry?.CheckInTime != null ? gp.VisitEntry.CheckInTime.Value.ToAppLocalTime().ToString("dd MMM yyyy hh:mm tt") : "Pending Check-In";
    var checkOutTimeText = gp?.VisitEntry?.CheckOutTime != null ? gp.VisitEntry.CheckOutTime.Value.ToAppLocalTime().ToString("dd MMM yyyy hh:mm tt") : "N/A";
}

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Entry Requests</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-circle-info me-2 text-primary"></i>Entry Request Details</h3>
            <p class="text-muted mb-0">Detailed view of the visitor entry request submission and approval timeline.</p>
        </div>
        <div class="d-flex gap-2">

            <a asp-action="Index" class="btn btn-outline-secondary px-3 rounded-2">Back to List</a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Details -->
        <div class="col-12 col-lg-8">
            <!-- Details Card -->
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white">
                <h5 class="fw-bold text-dark mb-4 border-bottom pb-2"><i class="fa-solid fa-file-invoice text-primary me-2"></i>Request Overview</h5>
                
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <span class="text-muted small d-block mb-1">Entry Request ID</span>
                        <span class="fw-bold text-dark font-monospace">#@Model.EntryRequestId</span>
                    </div>
                    <div class="col-12 col-md-6">
                        <span class="text-muted small d-block mb-1">Request Submission Date</span>
                        <span class="fw-bold text-dark">@Model.RequestDateTime.ToAppLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                    </div>

                    <div class="col-12">
                        <hr class="border-slate-100 my-2" />
                    </div>

                    <div class="col-12 col-md-6">
                        <span class="text-muted small d-block mb-1">Visitor Name</span>
                        <span class="fw-bold text-dark">@(Model.Visitor != null ? $"{Model.Visitor.FirstName} {Model.Visitor.LastName}" : "-")</span>
                    </div>
                    <div class="col-12 col-md-6">
                        <span class="text-muted small d-block mb-1">Visitor Contact Info</span>
                        <span class="fw-bold text-dark">@(Model.Visitor?.MobileNumber ?? "-") @(string.IsNullOrEmpty(Model.Visitor?.Email) ? "" : $"| {Model.Visitor.Email}")</span>
                    </div>

                    <div class="col-12 col-md-6">
                        <span class="text-muted small d-block mb-1">Visitor Company</span>
                        <span class="fw-bold text-dark">@(Model.Visitor?.CompanyName ?? "N/A")</span>
                    </div>
                    <div class="col-12 col-md-6">
                        <span class="text-muted small d-block mb-1">Purpose of Visit</span>
                        <span class="fw-bold text-dark text-wrap">@Model.Purpose</span>
                    </div>

                    <div class="col-12">
                        <hr class="border-slate-100 my-2" />
                    </div>

                    <div class="col-12 col-md-6">
                        <span class="text-muted small d-block mb-1">Host Employee</span>
                        <span class="fw-bold text-dark">@(Model.Employee != null ? $"{Model.Employee.FirstName} {Model.Employee.LastName}" : "-")</span>
                    </div>
                    <div class="col-12 col-md-6">
                        <span class="text-muted small d-block mb-1">Department</span>
                        <span class="fw-bold text-dark">@(Model.Department?.DepartmentName ?? "-")</span>
                    </div>
                </div>
            </div>

            <!-- Gate Pass / Visit Info Card (if approved) -->
            @if (Model.ApprovalStatus == "Approved" && gp != null)
            {
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                    <h5 class="fw-bold text-dark mb-4 border-bottom pb-2"><i class="fa-solid fa-ticket text-success me-2"></i>Pass & Live Status</h5>
                    
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <span class="text-muted small d-block mb-1">Pass Number</span>
                            <span class="fw-bold text-dark font-monospace">@gp.GatePassNumber</span>
                        </div>
                        <div class="col-12 col-md-6">
                            <span class="text-muted small d-block mb-1">Current Pass Status</span>
                            <div>
                                @if (gp.Status == "Approved")
                                {
                                    <span class="badge bg-primary-subtle text-primary px-3 py-1.5 rounded-pill fs-8"><i class="fa-solid fa-circle-check me-1"></i>Approved</span>
                                }
                                else if (gp.Status == "Checked In")
                                {
                                    <span class="badge bg-success-subtle text-success px-3 py-1.5 rounded-pill fs-8"><i class="fa-solid fa-circle-play me-1"></i>Checked In</span>
                                }
                                else if (gp.Status == "Checked Out" || gp.Status == "Closed")
                                {
                                    <span class="badge bg-secondary-subtle text-secondary px-3 py-1.5 rounded-pill fs-8"><i class="fa-solid fa-circle-stop me-1"></i>Checked Out</span>
                                }
                            </div>
                        </div>

                        <div class="col-12">
                            <hr class="border-slate-100 my-2" />
                        </div>

                        <div class="col-12 col-md-6">
                            <span class="text-muted small d-block mb-1">Check-In Time</span>
                            <span class="fw-bold text-dark">@checkInTimeText</span>
                        </div>
                        <div class="col-12 col-md-6">
                            <span class="text-muted small d-block mb-1">Check-Out Time</span>
                            <span class="fw-bold text-dark">@checkOutTimeText</span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar / Approval timeline -->
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white h-100">
                <h5 class="fw-bold text-dark mb-4 border-bottom pb-2"><i class="fa-solid fa-timeline text-primary me-2"></i>Workflow Log</h5>

                <div class="timeline-step mb-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="fa-solid fa-plus-circle"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold text-dark mb-0">Request Submitted</h6>
                            <span class="text-muted small">@Model.RequestDateTime.ToAppLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                        </div>
                    </div>
                </div>

                <div class="timeline-step">
                    <div class="d-flex align-items-center gap-3">
                        @if (Model.ApprovalStatus == "Pending")
                        {
                            <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="fa-solid fa-hourglass-half"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold text-dark mb-0">Pending</h6>
                                <span class="text-muted small">Awaiting Host Decision</span>
                            </div>
                        }
                        else if (Model.ApprovalStatus == "Approved")
                        {
                            <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="fa-solid fa-circle-check"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold text-dark mb-0">Approved by Host</h6>
                                <span class="text-muted small">@(Model.ApprovalDateTime?.ToAppLocalTime().ToString("dd MMM yyyy hh:mm tt") ?? "-")</span>
                                @if (!string.IsNullOrEmpty(Model.ApprovalRemarks))
                                {
                                    <div class="alert alert-light border border-slate-100 mt-2 py-1 px-2 mb-0 small text-muted">
                                        <strong>Remarks:</strong> @Model.ApprovalRemarks
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="fa-solid fa-circle-xmark"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold text-dark mb-0">Rejected by Host</h6>
                                <span class="text-muted small">@(Model.ApprovalDateTime?.ToAppLocalTime().ToString("dd MMM yyyy hh:mm tt") ?? "-")</span>
                                @if (!string.IsNullOrEmpty(Model.ApprovalRemarks))
                                {
                                    <div class="alert alert-light border border-slate-100 mt-2 py-1 px-2 mb-0 small text-muted">
                                        <strong>Remarks:</strong> @Model.ApprovalRemarks
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
