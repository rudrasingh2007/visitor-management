@model IEnumerable<VisitorManagementSystem.Models.EntryRequestMaster>
@using VisitorManagementSystem.Helpers
@{
    ViewData["Title"] = "Entry Requests";
}

<div class="container-fluid px-4 py-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-list-check me-2 text-primary"></i>Entry Requests</h3>
            <p class="text-muted mb-0">Manage and track all visitor entry requests.</p>
        </div>
        <div>
            @if (Context.Session.GetString("RoleName") != "Employee")
            {
                <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-3 shadow-sm"><i class="fa-solid fa-plus me-2"></i>Create Request</a>
            }
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="requestsTable" style="width: 100%;">
                <thead class="table-light text-muted fs-8 fw-semibold uppercase border-bottom-0">
                    <tr>
                        <th>Request Time</th>
                        <th>Visitor Name</th>
                        <th>Contact Number</th>
                        <th>Employee to Meet</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model)
                    {
                        <tr>
                            <td class="small text-dark">
                                @request.RequestDateTime.ToAppLocalTime().ToString("dd MMM yyyy")
                                <span class="text-muted d-block fs-8">@request.RequestDateTime.ToAppLocalTime().ToString("hh:mm tt")</span>
                            </td>
                            <td class="fw-semibold text-dark">@(request.Visitor != null ? $"{request.Visitor.FirstName} {request.Visitor.LastName}" : "-")</td>
                            <td class="text-muted small">@(request.Visitor?.MobileNumber ?? "-")</td>
                            <td class="small">@(request.Employee != null ? $"{request.Employee.FirstName} {request.Employee.LastName}" : "-")</td>
                            <td>
                                @{
                                    string displayStatus = request.ApprovalStatus;
                                    var latestGatePass = request.GatePasses?.OrderByDescending(g => g.CreatedDate).FirstOrDefault();
                                    if (latestGatePass != null)
                                    {
                                        if (latestGatePass.Status == "Checked In")
                                        {
                                            displayStatus = "Checked In";
                                        }
                                        else if (latestGatePass.Status == "Checked Out")
                                        {
                                            displayStatus = "Checked Out";
                                        }
                                    }
                                }
                                @switch (displayStatus)
                                {
                                    case "Pending":
                                        <span class="badge bg-warning-subtle text-warning px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-hourglass-half me-1"></i>Pending</span>
                                        break;
                                    case "Approved":
                                        <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-circle-check me-1"></i>Approved</span>
                                        break;
                                    case "Rejected":
                                        <span class="badge bg-danger-subtle text-danger px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-circle-xmark me-1"></i>Rejected</span>
                                        break;
                                    case "Checked In":
                                        <span class="badge bg-info-subtle text-info px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-right-to-bracket me-1"></i>Checked In</span>
                                        break;
                                    case "Checked Out":
                                        <span class="badge bg-secondary-subtle text-secondary px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-right-from-bracket me-1"></i>Checked Out</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary px-2.5 py-1.5 rounded-pill fs-9">@displayStatus</span>
                                        break;
                                }
                            </td>
                            <td class="text-end text-nowrap">
                                <a asp-action="Details" asp-route-id="@request.EntryRequestId" class="btn btn-sm btn-outline-info rounded-pill px-3 me-1" title="View Request Details">
                                    <i class="fa-solid fa-eye me-1"></i>View
                                </a>
                                @if (displayStatus == "Pending" && Context.HasPermission("Entry Requests", "Edit"))
                                {
                                    <button type="button" class="btn btn-sm btn-success rounded-pill px-3 me-1 btn-process-request" data-id="@request.EntryRequestId" data-action="Approve" title="Approve Request">
                                        <i class="fa-solid fa-check"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-danger rounded-pill px-3 btn-process-request" data-id="@request.EntryRequestId" data-action="Reject" title="Reject Request">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                }
                                else if (displayStatus == "Approved")
                                {
                                    <a asp-controller="GatePass" asp-action="Generate" asp-route-entryRequestId="@request.EntryRequestId" class="btn btn-sm btn-outline-primary rounded-pill px-3" title="Generate Visitor Pass">
                                        <i class="fa-solid fa-id-card-clip"></i>
                                    </a>
                                }
                                else if ((displayStatus == "Checked In" || displayStatus == "Checked Out") && latestGatePass != null)
                                {
                                    <a asp-controller="Visit" asp-action="PrintPass" asp-route-id="@latestGatePass.VisitEntryId" class="btn btn-sm btn-outline-secondary rounded-pill px-3" title="View Pass">
                                        <i class="fa-solid fa-id-card-clip"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Approval/Rejection Modal -->
<div class="modal fade" id="remarksModal" tabindex="-1" aria-labelledby="remarksModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="remarksModalLabel">Process Entry Request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="remarksForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="modalRequestId" value="" />
                <div class="modal-body py-3">
                    <p class="text-muted small mb-3">Please provide any remarks/notes for this action.</p>
                    <div class="mb-3">
                        <label for="approvalRemarks" class="form-label fw-semibold text-secondary">Remarks <span class="text-danger">*</span></label>
                        <textarea class="form-control rounded-3" id="approvalRemarks" name="approvalRemarks" rows="3" placeholder="Enter remarks here..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="submitModalBtn" class="btn btn-success rounded-pill px-4">Confirm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#requestsTable').DataTable({
                "order": [[0, "desc"]],
                "pageLength": 10,
                "columnDefs": [
                    { "orderable": false, "targets": -1 }
                ],
                "language": {
                    "search": "",
                    "searchPlaceholder": "Search requests...",
                    "lengthMenu": "Show _MENU_ entries"
                },
                "buttons": [
                    {
                        extend: 'excel',
                        className: 'btn btn-sm btn-success text-white me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-excel me-1"></i> Excel',
                        exportOptions: { columns: ':not(:last-child)' }
                    },
                    {
                        extend: 'pdf',
                        className: 'btn btn-sm btn-danger text-white me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-pdf me-1"></i> PDF',
                        exportOptions: { columns: ':not(:last-child)' }
                    },
                    {
                        extend: 'print',
                        className: 'btn btn-sm btn-secondary text-white rounded-2',
                        text: '<i class="fa-solid fa-print me-1"></i> Print',
                        exportOptions: { columns: ':not(:last-child)' }
                    }
                ],
                "dom": "<'row mb-3'<'col-sm-12 col-md-6'lB><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            $('.btn-process-request').on('click', function () {
                var id = $(this).data('id');
                var action = $(this).data('action');
                
                $('#modalRequestId').val(id);
                $('#remarksForm').attr('action', '/EntryRequest/' + action);
                
                if (action === 'Approve') {
                    $('#remarksModalLabel').text('Approve Entry Request');
                    $('#submitModalBtn').removeClass('btn-danger').addClass('btn-success').text('Approve');
                    $('#approvalRemarks').attr('placeholder', 'Enter approval remarks (e.g., Please proceed to meet)...');
                } else {
                    $('#remarksModalLabel').text('Reject Entry Request');
                    $('#submitModalBtn').removeClass('btn-success').addClass('btn-danger').text('Reject');
                    $('#approvalRemarks').attr('placeholder', 'Enter reason for rejection...');
                }
                
                $('#approvalRemarks').val('');
                
                var myModal = new bootstrap.Modal(document.getElementById('remarksModal'));
                myModal.show();
            });
        });
    </script>
}
