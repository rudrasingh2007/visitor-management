@model IEnumerable<VisitorManagementSystem.Models.EntryRequestMaster>
@{
    ViewData["Title"] = "Entry Requests";
}

<div class="container-fluid px-4 py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-list-check me-2 text-primary"></i>Entry Requests</h3>
            <p class="text-muted mb-0">Monitor the live status of visitor entry requests sent to employees for approval.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-3 shadow-sm"><i class="fa-solid fa-plus me-2"></i>Create Request</a>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="requestsTable" style="width: 100%;">
                <thead class="table-light text-muted fs-8 fw-semibold uppercase border-bottom-0">
                    <tr>
                        <th>Request Time</th>
                        <th>Visitor Name</th>
                        <th>Mobile Number</th>
                        <th>Department</th>
                        <th>Employee to Meet</th>
                        <th>Purpose</th>
                        <th>Status</th>
                        <th>Remarks</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model)
                    {
                        <tr>
                            <td class="small text-dark">
                                @request.RequestDateTime.ToLocalTime().ToString("dd MMM yyyy")
                                <span class="text-muted d-block fs-8">@request.RequestDateTime.ToLocalTime().ToString("hh:mm tt")</span>
                            </td>
                            <td class="fw-semibold text-dark">@(request.Visitor != null ? $"{request.Visitor.FirstName} {request.Visitor.LastName}" : "-")</td>
                            <td class="text-muted small">@(request.Visitor?.MobileNumber ?? "-")</td>
                            <td class="small">@(request.Department?.DepartmentName ?? "-")</td>
                            <td class="small">@(request.Employee != null ? $"{request.Employee.FirstName} {request.Employee.LastName}" : "-")</td>
                            <td class="small text-muted text-truncate" style="max-width: 150px;" title="@request.Purpose">@request.Purpose</td>
                            <td>
                                @switch (request.ApprovalStatus)
                                {
                                    case "Pending":
                                        <span class="badge bg-warning-subtle text-warning px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-hourglass-half me-1"></i>Pending</span>
                                        break;
                                    case "Approved":
                                        <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-circle-check me-1"></i>Approved</span>
                                        break;
                                    case "Rejected":
                                        <span class="badge bg-danger-subtle text-danger px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-circle-xmark me-1"></i>Rejected</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary px-2.5 py-1.5 rounded-pill fs-9">@request.ApprovalStatus</span>
                                        break;
                                }
                            </td>
                            <td class="small text-muted">@(request.ApprovalRemarks ?? "-")</td>
                            <td class="text-end">
                                @if (request.ApprovalStatus == "Approved")
                                {
                                    var gp = request.GatePasses.FirstOrDefault();
                                    if (gp != null && gp.VisitEntryId == null)
                                    {
                                        <a asp-controller="Visit" asp-action="CheckIn" class="btn btn-sm btn-outline-success rounded-pill px-3 me-1">
                                            <i class="fa-solid fa-user-check me-1"></i>Check-In
                                        </a>
                                    }
                                    if (gp != null)
                                    {
                                        <a asp-controller="GatePass" asp-action="Print" asp-route-id="@gp.GatePassId" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            <i class="fa-solid fa-print me-1"></i>Print Pass
                                        </a>
                                    }
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" disabled>
                                        <i class="fa-solid fa-ban me-1"></i>Locked
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#requestsTable').DataTable({
                "order": [[0, "desc"]],
                "pageLength": 10,
                "columnDefs": [
                    { "orderable": false, "targets": -1 }
                ],
                "language": {
                    "search": "Filter Requests:",
                    "lengthMenu": "Show _MENU_ entries"
                }
            });
        });
    </script>
}
