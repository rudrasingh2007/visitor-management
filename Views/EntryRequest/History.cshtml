@model IEnumerable<VisitorManagementSystem.Models.EntryRequestMaster>
@{
    ViewData["Title"] = "Approval History";
}

<div class="container-fluid px-4 py-4">
    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-clock-rotate-left me-2 text-primary"></i>Approval History</h3>
        <p class="text-muted mb-0">View all entry requests you have previously approved or rejected.</p>
    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-warning rounded-3 border-0">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>@ViewBag.Error
            </div>
        }
        else if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="bg-light d-inline-flex p-3 rounded-circle text-muted mb-3">
                    <i class="fa-solid fa-folder-open fa-2x"></i>
                </div>
                <h5 class="fw-bold text-dark mb-1">No History Found</h5>
                <p class="text-muted small">You haven't approved or rejected any visitor requests yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="historyTable" style="width: 100%;">
                    <thead class="table-light text-muted fs-8 fw-semibold uppercase border-bottom-0">
                        <tr>
                            <th>Processed Date</th>
                            <th>Visitor Name</th>
                            <th>Mobile Number</th>
                            <th>Company Name</th>
                            <th>Purpose</th>
                            <th>Status</th>
                            <th>Your Remarks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in Model)
                        {
                            <tr>
                                <td class="small text-dark">
                                    @(request.ApprovalDateTime.HasValue ? request.ApprovalDateTime.Value.ToAppLocalTime().ToString("dd MMM yyyy") : "-")
                                    <span class="text-muted d-block fs-8">@(request.ApprovalDateTime.HasValue ? request.ApprovalDateTime.Value.ToAppLocalTime().ToString("hh:mm tt") : "")</span>
                                </td>
                                <td class="fw-semibold text-dark">@(request.Visitor != null ? $"{request.Visitor.FirstName} {request.Visitor.LastName}" : "-")</td>
                                <td class="text-muted small">@(request.Visitor?.MobileNumber ?? "-")</td>
                                <td class="small text-dark">@(request.Visitor?.CompanyName ?? "N/A")</td>
                                <td class="small text-muted">@request.Purpose</td>
                                <td>
                                    @{
                                        string displayStatus = request.ApprovalStatus;
                                        var latestGatePass = request.GatePasses?.OrderByDescending(g => g.CreatedDate).FirstOrDefault();
                                        if (latestGatePass != null)
                                        {
                                            if (latestGatePass.Status == "Checked In")
                                            {
                                                displayStatus = "Checked In";
                                            }
                                            else if (latestGatePass.Status == "Checked Out")
                                            {
                                                displayStatus = "Checked Out";
                                            }
                                        }
                                    }
                                    @switch (displayStatus)
                                    {
                                        case "Approved":
                                            <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-circle-check me-1"></i>Approved</span>
                                            break;
                                        case "Rejected":
                                            <span class="badge bg-danger-subtle text-danger px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-circle-xmark me-1"></i>Rejected</span>
                                            break;
                                        case "Checked In":
                                            <span class="badge bg-info-subtle text-info px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-right-to-bracket me-1"></i>Checked In</span>
                                            break;
                                        case "Checked Out":
                                            <span class="badge bg-secondary-subtle text-secondary px-2.5 py-1.5 rounded-pill fs-9"><i class="fa-solid fa-right-from-bracket me-1"></i>Checked Out</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary px-2.5 py-1.5 rounded-pill fs-9">@displayStatus</span>
                                            break;
                                    }
                                </td>
                                <td class="small text-muted">@(request.ApprovalRemarks ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#historyTable').DataTable({
                "order": [[0, "desc"]],
                "pageLength": 10,
                "language": {
                    "search": "Filter History:"
                }
            });
        });
    </script>
}
