@model VisitorManagementSystem.Models.UserMaster
@{
    ViewData["Title"] = "User Details";
}

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">User List</a></li>
            <li class="breadcrumb-item active" aria-current="page">User Details</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-circle-info me-2 text-primary"></i>User Details</h3>
        <p class="text-muted mb-0">Detailed view of user profile and system information.</p>
    </div>

    <div class="row">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold fs-3 shadow-sm me-3" style="width:60px; height:60px; border-radius: 50%;">
                            @Model.FullName.Substring(0, Math.Min(2, Model.FullName.Length)).ToUpper()
                        </div>
                        <div>
                            <h4 class="fw-bold text-dark mb-0">@Model.FullName</h4>
                            <span class="badge bg-primary px-3 py-2 fs-8 mt-1">@(Model.Role?.RoleName ?? "No Role")</span>
                        </div>
                    </div>

                    <hr class="text-muted border-secondary opacity-25 mb-4" />

                    <!-- Details Grid -->
                    <div class="row g-3">

                        <!-- Username -->
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Username</span>
                            <span class="fw-semibold text-dark">@Model.Username</span>
                        </div>

                        <!-- Email -->
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Email Address</span>
                            <span class="fw-semibold text-dark">@Model.Email</span>
                        </div>

                        <!-- Mobile Number -->
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Mobile Number</span>
                            <span class="fw-semibold text-dark">@Model.MobileNumber</span>
                        </div>

                        <!-- Status -->
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Status</span>
                            @if (Model.Status == "Active")
                            {
                                <span class="badge bg-success-subtle text-success px-3 py-2 fs-8 rounded-pill mt-1"><i class="fa-solid fa-circle-check me-1"></i>Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger px-3 py-2 fs-8 rounded-pill mt-1"><i class="fa-solid fa-circle-xmark me-1"></i>Inactive</span>
                            }
                        </div>

                        <!-- Created Date -->
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Created Date</span>
                            <span class="fw-semibold text-dark">@Model.CreatedDate.ToAppLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                        </div>

                        <!-- Last Updated Date -->
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Last Updated Date</span>
                            <span class="fw-semibold text-dark">@(Model.LastUpdatedDate.HasValue ? Model.LastUpdatedDate.Value.ToAppLocalTime().ToString("dd MMM yyyy hh:mm tt") : "-")</span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-3 border-top border-secondary border-opacity-10">
                        <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-primary px-4 py-2 fw-semibold rounded-2 shadow-sm">
                            <i class="fa-solid fa-user-pen me-2"></i>Edit Profile
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-2">
                            Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-success-subtle { background-color: rgba(25, 135, 84, 0.1) !important; }
    .bg-danger-subtle { background-color: rgba(220, 53, 69, 0.1) !important; }
    .text-primary { color: #1e3c72 !important; }
    .fs-8 { font-size: 0.75rem; }
</style>
