@model VisitorManagementSystem.ViewModels.VisitorHistoryViewModel
@{
    ViewData["Title"] = "Visitor Activity Timeline";
}

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="VisitorHistory" asp-action="Index" class="text-decoration-none">Visitor History</a></li>
            <li class="breadcrumb-item active" aria-current="page">Activity Timeline</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-clock-rotate-left me-2 text-primary"></i>Visitor Activity Timeline</h3>
            <p class="text-muted mb-0">End-to-end timeline tracking appointments, visits, and gate passes for this visitor.</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary px-3 py-2 fw-semibold rounded-2">
                <i class="fa-solid fa-arrow-left me-1"></i>Back to History List
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column: Visitor Info Profile Card -->
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="bg-primary px-4 py-4 text-center text-white position-relative">
                    <!-- Photo -->
                    <div class="mx-auto mb-3 border border-3 border-white rounded-circle bg-white d-flex align-items-center justify-content-center overflow-hidden shadow-sm" style="width: 120px; height: 120px;">
                        @if (!string.IsNullOrEmpty(Model.Visitor.PhotoPath))
                        {
                            <img src="@Model.Visitor.PhotoPath" class="img-fluid" style="width:100%; height:100%; object-fit:cover;" alt="Visitor Photo" />
                        }
                        else
                        {
                            <i class="fa-solid fa-user fa-4x text-muted opacity-50"></i>
                        }
                    </div>
                    <h5 class="fw-bold mb-1">@Model.Visitor.FirstName @Model.Visitor.LastName</h5>
                    <span class="badge bg-white-50 text-dark px-3 py-1.5 rounded-pill fs-8 fw-semibold">
                        @(Model.Visitor.CompanyName ?? "Individual Visitor")
                    </span>
                </div>
                
                <div class="card-body p-4">
                    <h6 class="fw-bold text-dark mb-3 border-bottom pb-2">Profile Details</h6>
                    <div class="row g-2 mb-4 small">
                        <div class="col-4 text-muted">Gender:</div>
                        <div class="col-8 fw-semibold text-dark">@Model.Visitor.Gender</div>
                        
                        <div class="col-4 text-muted">Mobile No:</div>
                        <div class="col-8 fw-semibold text-dark">@Model.Visitor.MobileNumber</div>
                        
                        <div class="col-4 text-muted">Email:</div>
                        <div class="col-8 fw-semibold text-dark text-truncate" title="@Model.Visitor.Email">@Model.Visitor.Email</div>
                        
                        <div class="col-4 text-muted">ID Proof:</div>
                        <div class="col-8 fw-semibold text-dark">@Model.Visitor.IdProofType (@Model.Visitor.IdProofNumber)</div>
                        
                        <div class="col-4 text-muted">Address:</div>
                        <div class="col-8 fw-semibold text-dark">
                            @(Model.Visitor.Address ?? "-"), @(Model.Visitor.City ?? "-"), @(Model.Visitor.State ?? "-")
                        </div>
                        
                        <div class="col-4 text-muted">Joined On:</div>
                        <div class="col-8 fw-semibold text-dark">@Model.Visitor.CreatedDate.ToLocalTime().ToString("dd MMM yyyy")</div>
                    </div>

                    <h6 class="fw-bold text-dark mb-3 border-bottom pb-2">Summary Metrics</h6>
                    <div class="p-3 bg-light rounded-3 small">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Total Visits:</span>
                            <strong class="text-primary fs-6">@Model.TotalVisits</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Last Visit Date:</span>
                            <strong class="text-dark">
                                @(Model.LastVisitDate.HasValue ? Model.LastVisitDate.Value.ToLocalTime().ToString("dd MMM yyyy") : "N/A")
                            </strong>
                        </div>
                        <div class="mb-0">
                            <span class="text-muted d-block mb-1">Frequent Host Employee:</span>
                            <strong class="text-success text-truncate d-block" title="@Model.FrequentlyVisitedEmployee">
                                @Model.FrequentlyVisitedEmployee
                            </strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Tabs/Tables Timeline -->
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom p-0 rounded-top-4">
                    <ul class="nav nav-tabs card-header-tabs border-bottom-0 mx-2 mt-2" id="visitorTimelineTab" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active fw-bold text-secondary" id="visits-tab" data-bs-toggle="tab" data-bs-target="#visitsPanel" type="button" role="tab" aria-controls="visitsPanel" aria-selected="true">
                                <i class="fa-solid fa-door-open me-2 text-primary"></i>Visit Logs (@Model.VisitHistory.Count())
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link fw-bold text-secondary" id="appointments-tab" data-bs-toggle="tab" data-bs-target="#appointmentsPanel" type="button" role="tab" aria-controls="appointmentsPanel" aria-selected="false">
                                <i class="fa-solid fa-calendar-days me-2 text-success"></i>Appointments (@Model.AppointmentHistory.Count())
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link fw-bold text-secondary" id="gatepasses-tab" data-bs-toggle="tab" data-bs-target="#gatepassesPanel" type="button" role="tab" aria-controls="gatepassesPanel" aria-selected="false">
                                <i class="fa-solid fa-ticket me-2 text-warning"></i>Gate Passes (@Model.GatePassHistory.Count())
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-4">
                    <div class="tab-content" id="visitorTimelineTabContent">
                        
                        <!-- 1. Visit History Panel -->
                        <div class="tab-pane fade show active" id="visitsPanel" role="tabpanel" aria-labelledby="visits-tab">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle table-sm border-top" id="visitsHistoryTable" style="width:100%;">
                                    <thead class="table-light text-muted uppercase fs-8 fw-semibold">
                                        <tr>
                                            <th>Host Employee</th>
                                            <th>Check-In</th>
                                            <th>Check-Out</th>
                                            <th>Duration</th>
                                            <th>Status</th>
                                            <th>Remarks</th>
                                        </tr>
                                    </thead>
                                    <tbody class="fs-7">
                                        @foreach (var visit in Model.VisitHistory)
                                        {
                                            var durationText = "N/A";
                                            if (visit.CheckOutTime.HasValue)
                                            {
                                                var diff = visit.CheckOutTime.Value - visit.CheckInTime;
                                                durationText = $"{(int)diff.TotalHours}h {diff.Minutes}m";
                                            }
                                            <tr>
                                                <td>
                                                    <div class="fw-semibold">@(visit.Employee != null ? $"{visit.Employee.FirstName} {visit.Employee.LastName}" : "N/A")</div>
                                                    <span class="text-muted small">@(visit.Department?.DepartmentName ?? "N/A")</span>
                                                </td>
                                                <td>@visit.CheckInTime.ToLocalTime().ToString("dd-MM-yyyy hh:mm tt")</td>
                                                <td>@(visit.CheckOutTime.HasValue ? visit.CheckOutTime.Value.ToLocalTime().ToString("dd-MM-yyyy hh:mm tt") : "-")</td>
                                                <td class="fw-semibold">@durationText</td>
                                                <td>
                                                    @if (visit.VisitStatus == "Checked In")
                                                    {
                                                        <span class="badge bg-warning-subtle text-warning rounded-pill px-2 py-1 fs-8">Checked In</span>
                                                    }
                                                    else if (visit.VisitStatus == "In Meeting")
                                                    {
                                                        <span class="badge bg-info-subtle text-info rounded-pill px-2 py-1 fs-8">In Meeting</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-success-subtle text-success rounded-pill px-2 py-1 fs-8">Completed</span>
                                                    }
                                                </td>
                                                <td class="text-truncate" style="max-width: 120px;" title="@visit.Remarks">@(visit.Remarks ?? "-")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- 2. Appointment History Panel -->
                        <div class="tab-pane fade" id="appointmentsPanel" role="tabpanel" aria-labelledby="appointments-tab">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle table-sm border-top" id="appointmentsHistoryTable" style="width:100%;">
                                    <thead class="table-light text-muted uppercase fs-8 fw-semibold">
                                        <tr>
                                            <th>Host Employee</th>
                                            <th>Scheduled Date</th>
                                            <th>Time</th>
                                            <th>Status</th>
                                            <th>Purpose</th>
                                        </tr>
                                    </thead>
                                    <tbody class="fs-7">
                                        @foreach (var appt in Model.AppointmentHistory)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="fw-semibold">@(appt.Employee != null ? $"{appt.Employee.FirstName} {appt.Employee.LastName}" : "N/A")</div>
                                                    <span class="text-muted small">@(appt.Department?.DepartmentName ?? "N/A")</span>
                                                </td>
                                                <td>@appt.AppointmentDate.ToString("dd-MM-yyyy")</td>
                                                <td>@appt.AppointmentTime.ToString(@"hh\:mm")</td>
                                                <td>
                                                    @if (appt.Status == "Pending")
                                                    {
                                                        <span class="badge bg-warning-subtle text-warning rounded-pill px-2 py-1 fs-8">Pending</span>
                                                    }
                                                    else if (appt.Status == "Approved")
                                                    {
                                                        <span class="badge bg-success-subtle text-success rounded-pill px-2 py-1 fs-8">Approved</span>
                                                    }
                                                    else if (appt.Status == "Rejected")
                                                    {
                                                        <span class="badge bg-danger-subtle text-danger rounded-pill px-2 py-1 fs-8">Rejected</span>
                                                    }
                                                    else if (appt.Status == "Cancelled")
                                                    {
                                                        <span class="badge bg-secondary-subtle text-secondary rounded-pill px-2 py-1 fs-8">Cancelled</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-primary-subtle text-primary rounded-pill px-2 py-1 fs-8">Completed</span>
                                                    }
                                                </td>
                                                <td class="text-truncate" style="max-width: 150px;" title="@appt.Purpose">@appt.Purpose</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- 3. Gate Pass History Panel -->
                        <div class="tab-pane fade" id="gatepassesPanel" role="tabpanel" aria-labelledby="gatepasses-tab">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle table-sm border-top" id="gatepassesHistoryTable" style="width:100%;">
                                    <thead class="table-light text-muted uppercase fs-8 fw-semibold">
                                        <tr>
                                            <th>Pass No</th>
                                            <th>Issued On</th>
                                            <th>Valid Until</th>
                                            <th>QR Code</th>
                                            <th>Status</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody class="fs-7">
                                        @foreach (var pass in Model.GatePassHistory)
                                        {
                                            var isExpired = pass.Status == "Active" && DateTime.UtcNow > pass.ExpiryDateTime;
                                            var currentStatus = isExpired ? "Expired" : pass.Status;

                                            <tr>
                                                <td class="fw-bold"><i class="fa-solid fa-ticket text-warning-emphasis me-1"></i>@pass.GatePassNumber</td>
                                                <td>@pass.IssueDateTime.ToLocalTime().ToString("dd-MM-yyyy hh:mm tt")</td>
                                                <td>@pass.ExpiryDateTime.ToLocalTime().ToString("dd-MM-yyyy hh:mm tt")</td>
                                                <td>
                                                    <img src="@pass.QRCodePath" style="width: 32px; height: 32px;" class="border rounded" alt="QR" />
                                                </td>
                                                <td>
                                                    @if (currentStatus == "Active")
                                                    {
                                                        <span class="badge bg-success-subtle text-success rounded-pill px-2 py-1 fs-8">Active</span>
                                                    }
                                                    else if (currentStatus == "Expired")
                                                    {
                                                        <span class="badge bg-danger-subtle text-danger rounded-pill px-2 py-1 fs-8">Expired</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary-subtle text-secondary rounded-pill px-2 py-1 fs-8">Closed</span>
                                                    }
                                                </td>
                                                <td>
                                                    <a asp-controller="GatePass" asp-action="Print" asp-route-id="@pass.GatePassId" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill px-2 py-0.5 fs-8">
                                                        <i class="fa-solid fa-print me-1"></i>Print
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize simple DataTables for child history grids
            $('#visitsHistoryTable').DataTable({
                "paging": true,
                "lengthChange": false,
                "searching": true,
                "ordering": true,
                "info": true,
                "pageLength": 5,
                "order": [[1, "desc"]],
                "language": { "searchPlaceholder": "Search visit logs..." }
            });

            $('#appointmentsHistoryTable').DataTable({
                "paging": true,
                "lengthChange": false,
                "searching": true,
                "ordering": true,
                "info": true,
                "pageLength": 5,
                "order": [[1, "desc"]],
                "language": { "searchPlaceholder": "Search appointments..." }
            });

            $('#gatepassesHistoryTable').DataTable({
                "paging": true,
                "lengthChange": false,
                "searching": true,
                "ordering": true,
                "info": true,
                "pageLength": 5,
                "order": [[1, "desc"]],
                "language": { "searchPlaceholder": "Search gate passes..." }
            });

            // Adjust tabs styles
            $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
            });
        });
    </script>
}

<style>
    .bg-white-50 {
        background-color: rgba(255, 255, 255, 0.2) !important;
        color: #fff !important;
    }
    .fs-7 { font-size: 0.85rem; }
    .fs-8 { font-size: 0.75rem; }
    .nav-tabs .nav-link {
        border: none;
        border-bottom: 3px solid transparent;
        border-radius: 0;
        padding: 0.75rem 1rem;
    }
    .nav-tabs .nav-link.active {
        border-bottom-color: #1e3c72 !important;
        color: #1e3c72 !important;
        background: transparent !important;
    }
    .nav-tabs .nav-link:hover {
        border-bottom-color: #dee2e6;
    }
</style>
