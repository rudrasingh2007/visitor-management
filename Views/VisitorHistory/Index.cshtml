@model IEnumerable<VisitorManagementSystem.ViewModels.VisitorHistorySummaryViewModel>
@{
    ViewData["Title"] = "Visitor History";
}

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fa-solid fa-house me-1"></i>Home</a></li>
            <li class="breadcrumb-item text-muted">Reports & History</li>
            <li class="breadcrumb-item active" aria-current="page">Visitor History</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-clock-rotate-left me-2 text-primary"></i>Visitor History</h3>
            <p class="text-muted mb-0">Search and track complete, end-to-end activities and visits logs of all registered visitors.</p>
        </div>
    </div>

    <!-- Filters Card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-sliders text-primary me-2"></i>Filter History</h6>
            <div class="row g-3">
                <!-- Status Filter -->
                <div class="col-12 col-sm-6 col-md-4">
                    <label class="form-label fw-semibold text-muted small mb-1">Status</label>
                    <select id="statusFilter" class="form-select rounded-2">
                        <option value="">All Statuses</option>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
                <!-- Last Visit Date Range Filter -->
                <div class="col-12 col-sm-6 col-md-4">
                    <label class="form-label fw-semibold text-muted small mb-1">Last Visit Start Date</label>
                    <input type="date" id="startDateFilter" class="form-control rounded-2" />
                </div>
                <div class="col-12 col-sm-6 col-md-4">
                    <label class="form-label fw-semibold text-muted small mb-1">Last Visit End Date</label>
                    <input type="date" id="endDateFilter" class="form-control rounded-2" />
                </div>
            </div>
            <!-- Reset Button -->
            <div class="d-flex justify-content-end mt-3">
                <button type="button" id="btnResetFilters" class="btn btn-sm btn-outline-secondary rounded-2">
                    <i class="fa-solid fa-arrow-rotate-left me-1"></i>Reset Filters
                </button>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle" id="historyTable" style="width: 100%;">
                    <thead class="table-light text-muted uppercase fs-7 fw-semibold">
                        <tr>
                            <th>Photo</th>
                            <th>Visitor Name</th>
                            <th>Mobile</th>
                            <th>Email</th>
                            <th>Company</th>
                            <th class="text-center">Total Visits</th>
                            <th>Last Visit Date</th>
                            <th>Status</th>
                            <th class="text-end" style="min-width: 120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="avatar-circle-sm bg-light border rounded shadow-sm d-flex align-items-center justify-content-center overflow-hidden" style="width: 40px; height: 40px;">
                                        @if (!string.IsNullOrEmpty(item.PhotoPath))
                                        {
                                            <img src="@item.PhotoPath" class="img-fluid" style="width:100%; height:100%; object-fit:cover;" alt="Visitor" />
                                        }
                                        else
                                        {
                                            <i class="fa-solid fa-user text-muted"></i>
                                        }
                                    </div>
                                </td>
                                <td class="fw-semibold text-dark">@item.FullName</td>
                                <td>@item.MobileNumber</td>
                                <td class="text-truncate" style="max-width: 150px;">@item.Email</td>
                                <td>@(item.CompanyName ?? "-")</td>
                                <td class="text-center">
                                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-1fw-bold">
                                        @item.TotalVisits
                                    </span>
                                </td>
                                <td class="visit-date" data-date="@(item.LastVisitDate?.ToLocalTime().ToString("yyyy-MM-dd") ?? "")" data-order="@(item.LastVisitDate?.ToString("yyyyMMddHHmmss") ?? "00000000000000")">
                                    @(item.LastVisitDate.HasValue ? item.LastVisitDate.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt") : "Never Visited")
                                </td>
                                <td>
                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge bg-success-subtle text-success px-2 py-1 fs-8 rounded-pill">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-2 py-1 fs-8 rounded-pill">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.VisitorId" class="btn btn-sm btn-outline-primary px-3 rounded-2 fw-semibold" title="View Full Timeline">
                                        <i class="fa-solid fa-clock-rotate-left me-1"></i>Timeline
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize DataTable
            var table = $('#historyTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search visitor history..."
                },
                "order": [[6, "desc"]], // Order by Last Visit Date desc
                "buttons": [
                    {
                        extend: 'excel',
                        className: 'btn btn-sm btn-outline-success me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-excel me-1"></i> Excel',
                        exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] }
                    },
                    {
                        extend: 'pdf',
                        className: 'btn btn-sm btn-outline-danger me-1 rounded-2',
                        text: '<i class="fa-solid fa-file-pdf me-1"></i> PDF',
                        exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] }
                    },
                    {
                        extend: 'print',
                        className: 'btn btn-sm btn-outline-secondary rounded-2',
                        text: '<i class="fa-solid fa-print me-1"></i> Print',
                        exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] }
                    }
                ],
                "dom": "<'row mb-3'<'col-sm-12 col-md-6'lB><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            // Status Filter Dropdown
            $('#statusFilter').on('change', function() {
                var val = $(this).val();
                table.column(7).search(val ? '^\\s*' + val + '\\s*$' : '', true, false).draw();
            });

            // Custom Date Range filter
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    var startDateStr = $('#startDateFilter').val(); // YYYY-MM-DD
                    var endDateStr = $('#endDateFilter').val(); // YYYY-MM-DD
                    
                    var rowDateStr = $(table.row(dataIndex).node()).find('td.visit-date').attr('data-date');
                    if (!rowDateStr) {
                        return !startDateStr && !endDateStr; // Keep only if no date filter active
                    }
                    
                    var rowDate = new Date(rowDateStr);
                    rowDate.setHours(0,0,0,0);

                    if (startDateStr) {
                        var startDate = new Date(startDateStr);
                        startDate.setHours(0,0,0,0);
                        if (rowDate < startDate) return false;
                    }
                    if (endDateStr) {
                        var endDate = new Date(endDateStr);
                        endDate.setHours(0,0,0,0);
                        if (rowDate > endDate) return false;
                    }
                    return true;
                }
            );

            // Re-draw when dates change
            $('#startDateFilter, #endDateFilter').on('change', function() {
                table.draw();
            });

            // Reset Filters
            $('#btnResetFilters').click(function() {
                $('#statusFilter').val('');
                $('#startDateFilter').val('');
                $('#endDateFilter').val('');
                
                table.column(7).search('');
                table.draw();
            });
        });
    </script>
}

<style>
    .fs-7 { font-size: 0.85rem; }
    .fs-8 { font-size: 0.75rem; }
</style>
